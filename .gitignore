# Node / CLI
node_modules/
npm-debug.log*
dist/

# Evidencia de Gemba: el bulto no se versiona; lo CITADO desde HANDOFF/CHANGELOG
# se commitea selectivamente con `git add -f qa_runs/<corrida>/<archivo>` (paso
# obligatorio del cierre — ver qa_runs/README.md). El README sí se versiona.
qa_runs/*/

# Plan de trabajo del dia (ADR 0006): efimero con hogar persistente. Sobrevive
# la compactacion pero NO se versiona. Patron ANCLADO con '/' a la raiz para no
# ignorar por accidente kit/.jidoka/ (el kit versionado).
/.jidoka/

# Marcadores de revision de los Stop hooks (review-stop, gemba-stop): guardan el
# SHA del diff ya revisado/aprobado por el humano. Son estado local, no se versionan.
.claude/.review-marker
.claude/.gemba-marker

# SO / editor
.DS_Store
Thumbs.db
*.swp
# .vscode se ignora salvo la config de proyecto que SI viaja con el repo: la
# recomendacion de extensiones y los settings de workspace (asociar los .bpmn/.dmn
# al editor visual del atlas y fijar el default de markdown). No se puede des-ignorar
# un archivo si su carpeta esta excluida por completo, por eso se ignora el contenido,
# no la carpeta.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Temporales
*.tmp
*.log

# Capturas PNG de inspeccion del atlas: scratch para ver a ojo. El render
# versionado es el .svg (npm run atlas:render); los PNG son desechables.
docs/atlas/render/*.png

# Gate anti-PII: la denylist local (cadenas literales del entorno del operador:
# cuentas secundarias, correos, hostnames) NUNCA se commitea -- meterla al repo
# publica lo que busca frenar. El formato vive en anti-pii.denylist.example.txt.
tools/anti-pii.denylist.txt
