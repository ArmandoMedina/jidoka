# Node / CLI
node_modules/
npm-debug.log*
dist/

# Evidencia de Gemba: el bulto no se versiona; lo CITADO desde HANDOFF/CHANGELOG
# se commitea selectivamente con `git add -f qa_runs/<corrida>/<archivo>` (paso
# obligatorio del cierre — ver qa_runs/README.md). El README sí se versiona.
qa_runs/*/

# Plan de trabajo del dia (ADR 0006): efimero con hogar persistente. Sobrevive
# la compactacion pero NO se versiona. Patron ANCLADO con '/' a la raiz para no
# ignorar por accidente kit/.jidoka/ (el kit versionado).
/.jidoka/

# Marcadores de revision de los Stop hooks (review-stop, gemba-stop): guardan el
# SHA del diff ya revisado/aprobado por el humano. Son estado local, no se versionan.
.claude/.review-marker
.claude/.gemba-marker

# SO / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Temporales
*.tmp
*.log
