#!/bin/sh
# pre-push - dispara el Andon local (la ley tools/blast-radius.json) antes de cada
# push. AVISA los doc_avisa faltantes y BLOQUEA los doc_bloquea. Jidoka corre su
# propio Andon (dogfooding).
# Se enciende una vez por clon:  git config core.hooksPath .githooks
# Saltar a proposito:            git push --no-verify
powershell -NoProfile -ExecutionPolicy Bypass -File "./tools/verificar.ps1"
rc=$?
# Gate anti-PII: fuga de dato de entorno en docs rastreados (disparo sin-pii-en-el-repo).
powershell -NoProfile -ExecutionPolicy Bypass -File "./tools/anti-pii.ps1"
ra=$?
# Gate de ligas codigo<->capacidad (ledger tools/ligas.json; -Estricto = las 'bloquea' muerden).
powershell -NoProfile -ExecutionPolicy Bypass -File "./tools/estado-ligas.ps1" -Estricto
rl=$?
if [ "$rc" -ne 0 ]; then exit "$rc"; fi
if [ "$ra" -ne 0 ]; then exit "$ra"; fi
exit "$rl"
