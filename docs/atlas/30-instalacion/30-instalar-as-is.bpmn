<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_30_Instalar" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_Instalar" name="Instalar Jidoka en un repositorio" isExecutable="false">
    <bpmn:documentation>Fuente: tools/instalar.ps1 y manifiesto de siembra</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Destino</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Destino" name="Resolver y preparar repositorio destino">
      <bpmn:incoming>F_Start_Task_Destino</bpmn:incoming>
      <bpmn:outgoing>F_Task_Destino_Task_Arquetipo</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Destino" sourceRef="Start" targetRef="Task_Destino"/>
    <bpmn:userTask id="Task_Arquetipo" name="Elegir arquetipo">
      <bpmn:incoming>F_Task_Destino_Task_Arquetipo</bpmn:incoming>
      <bpmn:outgoing>F_Task_Arquetipo_Task_Sembrar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Destino_Task_Arquetipo" sourceRef="Task_Destino" targetRef="Task_Arquetipo"/>
    <bpmn:serviceTask id="Task_Sembrar" name="Sembrar la mecánica sin sobrescribir">
      <bpmn:incoming>F_Task_Arquetipo_Task_Sembrar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Sembrar_Task_Instancia</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Arquetipo_Task_Sembrar" sourceRef="Task_Arquetipo" targetRef="Task_Sembrar"/>
    <bpmn:serviceTask id="Task_Instancia" name="Crear stubs y ley de la instancia">
      <bpmn:incoming>F_Task_Sembrar_Task_Instancia</bpmn:incoming>
      <bpmn:outgoing>F_Task_Instancia_Task_Hooks</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Sembrar_Task_Instancia" sourceRef="Task_Sembrar" targetRef="Task_Instancia"/>
    <bpmn:serviceTask id="Task_Hooks" name="Configurar core.hooksPath">
      <bpmn:incoming>F_Task_Instancia_Task_Hooks</bpmn:incoming>
      <bpmn:outgoing>F_Task_Hooks_Task_Sello</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Instancia_Task_Hooks" sourceRef="Task_Instancia" targetRef="Task_Hooks"/>
    <bpmn:serviceTask id="Task_Sello" name="Escribir sello del motor">
      <bpmn:incoming>F_Task_Hooks_Task_Sello</bpmn:incoming>
      <bpmn:outgoing>F_Task_Sello_Task_Smoke</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Hooks_Task_Sello" sourceRef="Task_Hooks" targetRef="Task_Sello"/>
    <bpmn:serviceTask id="Task_Smoke" name="Ejecutar prueba de instalación">
      <bpmn:incoming>F_Task_Sello_Task_Smoke</bpmn:incoming>
      <bpmn:outgoing>F_Task_Smoke_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Sello_Task_Smoke" sourceRef="Task_Sello" targetRef="Task_Smoke"/>
    <bpmn:endEvent id="End" name="Método sembrado y probado">
      <bpmn:incoming>F_Task_Smoke_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Smoke_End" sourceRef="Task_Smoke" targetRef="End"/>
  </bpmn:process>
