<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_JidokaArranque" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:message id="Message_SolicitudArranque" name="Solicitud /jidoka:arranca" />
  <bpmn:message id="Message_SolicitudAclaracion" name="Solicitud de aclaración o decisión" />
  <bpmn:message id="Message_RespuestaUsuario" name="Respuesta del usuario" />
  <bpmn:message id="Message_Orientacion" name="Orientación y propuesta" />
  <bpmn:collaboration id="Collaboration_JidokaArranque">
    <bpmn:participant id="Participant_Usuario" name="Usuario" />
    <bpmn:participant id="Participant_Proyecto" name="Proyecto gobernado con Jidoka" processRef="Process_ArranqueSesion" />
    <bpmn:messageFlow id="MessageFlow_Iniciar" name="/jidoka:arranca" sourceRef="Participant_Usuario" targetRef="StartEvent_Solicitud" messageRef="Message_SolicitudArranque" />
    <bpmn:messageFlow id="MessageFlow_PedirAclaracion" sourceRef="SendTask_SolicitarAclaracion" targetRef="Participant_Usuario" messageRef="Message_SolicitudAclaracion" />
    <bpmn:messageFlow id="MessageFlow_Responder" sourceRef="Participant_Usuario" targetRef="CatchEvent_Respuesta" messageRef="Message_RespuestaUsuario" />
    <bpmn:messageFlow id="MessageFlow_Orientar" sourceRef="SendTask_PresentarOrientacion" targetRef="Participant_Usuario" messageRef="Message_Orientacion" />
    <bpmn:textAnnotation id="TextAnnotation_ReglaArranque">
      <bpmn:text>/jidoka:arranca orienta la sesión. No modifica el producto ni inicia construcción.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_LecturaMinima">
      <bpmn:text>Lectura progresiva: primero contexto mínimo; después solo documentos activados por la retoma, el objetivo o el router.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_ReglaArranque" sourceRef="TextAnnotation_ReglaArranque" targetRef="EndEvent_SesionOrientada" />
    <bpmn:association id="Association_LecturaMinima" sourceRef="TextAnnotation_LecturaMinima" targetRef="Task_LeerDocumentosActivados" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ArranqueSesion" name="Arrancar una sesión gobernada con Jidoka" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Arranque">
      <bpmn:lane id="Lane_Motor" name="Motor Jidoka / repositorio">
        <bpmn:flowNodeRef>ServiceTask_InspeccionarEstado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_EjecutarRouter</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Agente" name="Agente orquestador">
        <bpmn:flowNodeRef>Gateway_UnirPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DelimitarSesion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FaltaContexto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_SolicitarAclaracion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_Respuesta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LeerDocumentosActivados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluarTamanoRiesgo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RequierePlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_PresentarOrientacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_UnirPropuesta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecomendarPlanea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProponerAccion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SesionOrientada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Solicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LeerRelevo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LeerRecursos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HayTrabajoActivo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LeerPlanActivo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:serviceTask id="ServiceTask_InspeccionarEstado" name="Inspeccionar Git y estado del motor">
      <bpmn:incoming>Flow_Unir_Inspeccionar</bpmn:incoming>
      <bpmn:outgoing>Flow_Inspeccionar_Router</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_EjecutarRouter" name="Ejecutar el router de reglas aplicables">
      <bpmn:incoming>Flow_Inspeccionar_Router</bpmn:incoming>
      <bpmn:outgoing>Flow_Router_Delimitar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_UnirPlan">
      <bpmn:incoming>Flow_Plan_Unir</bpmn:incoming>
      <bpmn:incoming>Flow_NoHayTrabajo</bpmn:incoming>
      <bpmn:outgoing>Flow_Unir_Inspeccionar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataObjectReference id="DataObjectReference_Estado" name="Git + jidoka-motor.json" dataObjectRef="DataObject_Estado" />
    <bpmn:dataObject id="DataObject_Estado" name="Git + jidoka-motor.json" />
    <bpmn:dataObjectReference id="DataObjectReference_Ley" name="tools/blast-radius.json" dataObjectRef="DataObject_Ley" />
    <bpmn:dataObject id="DataObject_Ley" name="tools/blast-radius.json" />
    <bpmn:task id="Task_DelimitarSesion" name="Delimitar objetivo, alcance y riesgo de la sesión">
      <bpmn:incoming>Flow_Router_Delimitar</bpmn:incoming>
      <bpmn:incoming>Flow_Respuesta_Delimitar</bpmn:incoming>
      <bpmn:outgoing>Flow_Delimitar_FaltaContexto</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_FaltaContexto" name="¿Falta contexto crítico o existe una contradicción?" default="Flow_ContextoSuficiente">
      <bpmn:incoming>Flow_Delimitar_FaltaContexto</bpmn:incoming>
      <bpmn:outgoing>Flow_ContextoSuficiente</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="SendTask_SolicitarAclaracion" name="Solicitar aclaración o decisión al usuario" messageRef="Message_SolicitudAclaracion">
      <bpmn:incoming>Flow_ContextoSuficiente</bpmn:incoming>
      <bpmn:outgoing>Flow_Solicitar_Esperar</bpmn:outgoing>
      <bpmn:outgoing>Flow_1kbkfcc</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchEvent_Respuesta" name="Respuesta del usuario recibida">
      <bpmn:incoming>Flow_Solicitar_Esperar</bpmn:incoming>
      <bpmn:outgoing>Flow_Respuesta_Delimitar</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Respuesta" messageRef="Message_RespuestaUsuario" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_LeerDocumentosActivados" name="Leer solo la documentación activada">
      <bpmn:incoming>Flow_1kbkfcc</bpmn:incoming>
      <bpmn:outgoing>Flow_Documentos_Evaluar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EvaluarTamanoRiesgo" name="Evaluar tamaño, valor y riesgo del trabajo">
      <bpmn:incoming>Flow_Documentos_Evaluar</bpmn:incoming>
      <bpmn:outgoing>Flow_Evaluar_RequierePlan</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RequierePlan" name="¿Requiere un plan aprobado?" default="Flow_NoRequierePlan">
      <bpmn:incoming>Flow_Evaluar_RequierePlan</bpmn:incoming>
      <bpmn:outgoing>Flow_SiRequierePlan</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoRequierePlan</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="SendTask_PresentarOrientacion" name="Presentar orientación, límites y siguiente paso" messageRef="Message_Orientacion">
      <bpmn:incoming>Flow_Unir_Presentar</bpmn:incoming>
      <bpmn:outgoing>Flow_Presentar_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_UnirPropuesta">
      <bpmn:incoming>Flow_Planea_Unir</bpmn:incoming>
      <bpmn:incoming>Flow_Accion_Unir</bpmn:incoming>
      <bpmn:outgoing>Flow_Unir_Presentar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RecomendarPlanea" name="Recomendar /jidoka:planea">
      <bpmn:incoming>Flow_SiRequierePlan</bpmn:incoming>
      <bpmn:outgoing>Flow_Planea_Unir</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProponerAccion" name="Preparar una siguiente acción acotada">
      <bpmn:incoming>Flow_NoRequierePlan</bpmn:incoming>
      <bpmn:outgoing>Flow_Accion_Unir</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_SesionOrientada" name="Sesión orientada; construcción no iniciada">
      <bpmn:incoming>Flow_Presentar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataObjectReference id="DataObjectReference_Documentos" name="Documentos específicos activados" dataObjectRef="DataObject_Documentos" />
    <bpmn:dataObject id="DataObject_Documentos" name="Documentos específicos activados" />
    <bpmn:startEvent id="StartEvent_Solicitud" name="Solicitud de arranque recibida">
      <bpmn:outgoing>Flow_Start_LeerRelevo</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Start" messageRef="Message_SolicitudArranque" />
    </bpmn:startEvent>
    <bpmn:task id="Task_LeerRelevo" name="Leer el relevo de la sesión">
      <bpmn:incoming>Flow_Start_LeerRelevo</bpmn:incoming>
      <bpmn:outgoing>Flow_LeerRelevo_LeerRecursos</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_LeerRecursos" name="Leer recursos y casting del proyecto">
      <bpmn:incoming>Flow_LeerRelevo_LeerRecursos</bpmn:incoming>
      <bpmn:outgoing>Flow_LeerRecursos_HayTrabajo</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_HayTrabajoActivo" name="¿Hay trabajo activo o una retoma explícita?" default="Flow_NoHayTrabajo">
      <bpmn:incoming>Flow_LeerRecursos_HayTrabajo</bpmn:incoming>
      <bpmn:outgoing>Flow_SiHayTrabajo</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoHayTrabajo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_LeerPlanActivo" name="Leer plan activo y referencias de retoma">
      <bpmn:incoming>Flow_SiHayTrabajo</bpmn:incoming>
      <bpmn:outgoing>Flow_Plan_Unir</bpmn:outgoing>
    </bpmn:task>
    <bpmn:dataObjectReference id="DataObjectReference_HANDOFF" name="HANDOFF.md" dataObjectRef="DataObject_HANDOFF" />
    <bpmn:dataObject id="DataObject_HANDOFF" name="HANDOFF.md" />
    <bpmn:dataObjectReference id="DataObjectReference_Recursos" name="recursos-del-proyecto.md" dataObjectRef="DataObject_Recursos" />
    <bpmn:dataObject id="DataObject_Recursos" name="recursos-del-proyecto.md" />
    <bpmn:dataObjectReference id="DataObjectReference_Plan" name="Plan activo + referencias de retoma" dataObjectRef="DataObject_Plan" />
    <bpmn:dataObject id="DataObject_Plan" name="Plan activo + referencias de retoma" />
    <bpmn:sequenceFlow id="Flow_Unir_Inspeccionar" sourceRef="Gateway_UnirPlan" targetRef="ServiceTask_InspeccionarEstado" />
    <bpmn:sequenceFlow id="Flow_Inspeccionar_Router" sourceRef="ServiceTask_InspeccionarEstado" targetRef="ServiceTask_EjecutarRouter" />
    <bpmn:sequenceFlow id="Flow_Router_Delimitar" sourceRef="ServiceTask_EjecutarRouter" targetRef="Task_DelimitarSesion" />
    <bpmn:sequenceFlow id="Flow_NoHayTrabajo" name="No" sourceRef="Gateway_HayTrabajoActivo" targetRef="Gateway_UnirPlan" />
    <bpmn:sequenceFlow id="Flow_Plan_Unir" sourceRef="Task_LeerPlanActivo" targetRef="Gateway_UnirPlan" />
    <bpmn:sequenceFlow id="Flow_Respuesta_Delimitar" sourceRef="CatchEvent_Respuesta" targetRef="Task_DelimitarSesion" />
    <bpmn:sequenceFlow id="Flow_Delimitar_FaltaContexto" sourceRef="Task_DelimitarSesion" targetRef="Gateway_FaltaContexto" />
    <bpmn:sequenceFlow id="Flow_ContextoSuficiente" name="No" sourceRef="Gateway_FaltaContexto" targetRef="SendTask_SolicitarAclaracion" />
    <bpmn:sequenceFlow id="Flow_Solicitar_Esperar" sourceRef="SendTask_SolicitarAclaracion" targetRef="CatchEvent_Respuesta" />
    <bpmn:sequenceFlow id="Flow_1kbkfcc" sourceRef="SendTask_SolicitarAclaracion" targetRef="Task_LeerDocumentosActivados" />
    <bpmn:sequenceFlow id="Flow_Documentos_Evaluar" sourceRef="Task_LeerDocumentosActivados" targetRef="Task_EvaluarTamanoRiesgo" />
    <bpmn:sequenceFlow id="Flow_Evaluar_RequierePlan" sourceRef="Task_EvaluarTamanoRiesgo" targetRef="Gateway_RequierePlan" />
    <bpmn:sequenceFlow id="Flow_SiRequierePlan" name="Sí" sourceRef="Gateway_RequierePlan" targetRef="Task_RecomendarPlanea">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">requierePlanAprobado = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoRequierePlan" name="No" sourceRef="Gateway_RequierePlan" targetRef="Task_ProponerAccion" />
    <bpmn:sequenceFlow id="Flow_Unir_Presentar" sourceRef="Gateway_UnirPropuesta" targetRef="SendTask_PresentarOrientacion" />
    <bpmn:sequenceFlow id="Flow_Presentar_End" sourceRef="SendTask_PresentarOrientacion" targetRef="EndEvent_SesionOrientada" />
    <bpmn:sequenceFlow id="Flow_Planea_Unir" sourceRef="Task_RecomendarPlanea" targetRef="Gateway_UnirPropuesta" />
    <bpmn:sequenceFlow id="Flow_Accion_Unir" sourceRef="Task_ProponerAccion" targetRef="Gateway_UnirPropuesta" />
    <bpmn:sequenceFlow id="Flow_Start_LeerRelevo" sourceRef="StartEvent_Solicitud" targetRef="Task_LeerRelevo" />
    <bpmn:sequenceFlow id="Flow_LeerRelevo_LeerRecursos" sourceRef="Task_LeerRelevo" targetRef="Task_LeerRecursos" />
    <bpmn:sequenceFlow id="Flow_LeerRecursos_HayTrabajo" sourceRef="Task_LeerRecursos" targetRef="Gateway_HayTrabajoActivo" />
    <bpmn:sequenceFlow id="Flow_SiHayTrabajo" name="Sí" sourceRef="Gateway_HayTrabajoActivo" targetRef="Task_LeerPlanActivo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">hayTrabajoActivo = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:association id="Association_Estado" associationDirection="One" sourceRef="DataObjectReference_Estado" targetRef="ServiceTask_InspeccionarEstado" />
    <bpmn:association id="Association_Ley" associationDirection="One" sourceRef="DataObjectReference_Ley" targetRef="ServiceTask_EjecutarRouter" />
    <bpmn:association id="Association_Documentos" associationDirection="One" sourceRef="DataObjectReference_Documentos" targetRef="Task_LeerDocumentosActivados" />
    <bpmn:association id="Association_HANDOFF" associationDirection="One" sourceRef="DataObjectReference_HANDOFF" targetRef="Task_LeerRelevo" />
    <bpmn:association id="Association_Recursos" associationDirection="One" sourceRef="DataObjectReference_Recursos" targetRef="Task_LeerRecursos" />
    <bpmn:association id="Association_Plan" associationDirection="One" sourceRef="DataObjectReference_Plan" targetRef="Task_LeerPlanActivo" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_JidokaArranque">
    <bpmndi:BPMNPlane id="BPMNPlane_JidokaArranque" bpmnElement="Collaboration_JidokaArranque">
      <bpmndi:BPMNShape id="Shape_Participant_Usuario" bpmnElement="Participant_Usuario" isHorizontal="true">
        <dc:Bounds x="160" y="50" width="3680" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Participant_Proyecto" bpmnElement="Participant_Proyecto" isHorizontal="true">
        <dc:Bounds x="160" y="180" width="3680" height="630" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Motor" bpmnElement="Lane_Motor" isHorizontal="true">
        <dc:Bounds x="190" y="540" width="3650" height="270" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Agente" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="190" y="180" width="3650" height="360" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Service_Inspeccionar" bpmnElement="ServiceTask_InspeccionarEstado">
        <dc:Bounds x="1200" y="600" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Service_Router" bpmnElement="ServiceTask_EjecutarRouter">
        <dc:Bounds x="1430" y="600" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_UnirPlan" bpmnElement="Gateway_UnirPlan" isMarkerVisible="true">
        <dc:Bounds x="1165" y="455" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_Estado" bpmnElement="DataObjectReference_Estado">
        <dc:Bounds x="1317" y="715" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1280" y="775" width="110" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_Ley" bpmnElement="DataObjectReference_Ley">
        <dc:Bounds x="1520" y="715" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1484" y="775" width="107" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Delimitar" bpmnElement="Task_DelimitarSesion">
        <dc:Bounds x="1665" y="330" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_FaltaContexto" bpmnElement="Gateway_FaltaContexto" isMarkerVisible="true">
        <dc:Bounds x="1905" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1867.5" y="405" width="125" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Send_Solicitar" bpmnElement="SendTask_SolicitarAclaracion">
        <dc:Bounds x="2020" y="330" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Catch_Respuesta" bpmnElement="CatchEvent_Respuesta">
        <dc:Bounds x="2242" y="270" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2288" y="274" width="110" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_LeerDocs" bpmnElement="Task_LeerDocumentosActivados">
        <dc:Bounds x="2450" y="330" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Evaluar" bpmnElement="Task_EvaluarTamanoRiesgo">
        <dc:Bounds x="2780" y="330" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_RequierePlan" bpmnElement="Gateway_RequierePlan" isMarkerVisible="true">
        <dc:Bounds x="3035" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3094.5" y="356.5" width="91" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Send_Presentar" bpmnElement="SendTask_PresentarOrientacion">
        <dc:Bounds x="3475" y="330" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_UnirPropuesta" bpmnElement="Gateway_UnirPropuesta" isMarkerVisible="true">
        <dc:Bounds x="3355" y="345" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Planea" bpmnElement="Task_RecomendarPlanea">
        <dc:Bounds x="3145" y="245" width="170" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Accion" bpmnElement="Task_ProponerAccion">
        <dc:Bounds x="3145" y="415" width="170" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End" bpmnElement="EndEvent_SesionOrientada">
        <dc:Bounds x="3742" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3703" y="394" width="118" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_Documentos" bpmnElement="DataObjectReference_Documentos">
        <dc:Bounds x="2533" y="455" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2466" y="510" width="170" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent_Solicitud">
        <dc:Bounds x="252" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="220" y="344" width="104" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_LeerRelevo" bpmnElement="Task_LeerRelevo">
        <dc:Bounds x="340" y="280" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_LeerRecursos" bpmnElement="Task_LeerRecursos">
        <dc:Bounds x="530" y="280" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_HayTrabajo" bpmnElement="Gateway_HayTrabajoActivo" isMarkerVisible="true">
        <dc:Bounds x="760" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="732" y="258" width="106" height="27" />
