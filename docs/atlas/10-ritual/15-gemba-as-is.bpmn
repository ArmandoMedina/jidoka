<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_15_Gemba" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_Gemba" name="/jidoka:gemba — demostrar el incremento" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/gemba.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Correr</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Correr" name="Correr el producto real E2E">
      <bpmn:incoming>F_Start_Task_Correr</bpmn:incoming>
      <bpmn:outgoing>F_Task_Correr_Task_Evidencia</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Start_Task_Correr" sourceRef="Start" targetRef="Task_Correr"/>
    <bpmn:task id="Task_Evidencia" name="Guardar LOG.md y artefactos de la corrida">
      <bpmn:incoming>F_Task_Correr_Task_Evidencia</bpmn:incoming>
      <bpmn:outgoing>F_Task_Evidencia_Task_Presentar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Correr_Task_Evidencia" sourceRef="Task_Correr" targetRef="Task_Evidencia"/>
    <bpmn:userTask id="Task_Presentar" name="Presentar la evidencia al cliente">
      <bpmn:incoming>F_Task_Evidencia_Task_Presentar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Presentar_Task_Vercedicto</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Evidencia_Task_Presentar" sourceRef="Task_Evidencia" targetRef="Task_Presentar"/>
    <bpmn:task id="Task_Vercedicto" name="Registrar el veredicto fuera de qa_runs">
      <bpmn:incoming>F_Task_Presentar_Task_Vercedicto</bpmn:incoming>
      <bpmn:outgoing>F_Task_Vercedicto_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Presentar_Task_Vercedicto" sourceRef="Task_Presentar" targetRef="Task_Vercedicto"/>
    <bpmn:endEvent id="End" name="Demo evaluado con evidencia">
      <bpmn:incoming>F_Task_Vercedicto_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Vercedicto_End" sourceRef="Task_Vercedicto" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_15_Gemba">
    <bpmndi:BPMNPlane id="Plane_Diagram_15_Gemba" bpmnElement="Process_Gemba">
