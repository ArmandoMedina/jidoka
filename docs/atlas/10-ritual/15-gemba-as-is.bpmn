<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_15_Gemba" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collab_Gemba">
    <bpmn:participant id="Pool_Gemba" name="/jidoka:gemba — el demo que verifica el cliente" processRef="Process_Gemba"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Gemba" name="/jidoka:gemba — producir la evidencia real del incremento" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/gemba.md. Carriles: el Agente corre el demo y surte la evidencia; el checkpoint visual lo responde el Humano con sus ojos.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Gemba">
      <bpmn:lane id="Lane_Agente" name="Agente (surte la evidencia)">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_CorrerDemo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Artefactos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Tipo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Veredicto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Corregir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Citar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Humano" name="Humano (cliente)">
        <bpmn:flowNodeRef>U_Cliente</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Incremento a demostrar">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_CorrerDemo" name="Correr el demo E2E desde el producto real (no un script por fuera)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="T_Artefactos" name="Dejar artefactos y LOG.md en qa_runs/ (datos sintéticos)">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Tipo" name="¿Objetivo o subjetivo/visual?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f_obj</bpmn:outgoing>
      <bpmn:outgoing>f_subj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Veredicto" name="Veredicto por artefacto (test verde, tabla N/N)">
      <bpmn:incoming>f_obj</bpmn:incoming>
      <bpmn:outgoing>f_ver_citar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="U_Cliente" name="STOP: ¿se ve bien? lo responde el cliente con sus ojos">
      <bpmn:incoming>f_subj</bpmn:incoming>
      <bpmn:outgoing>f_cli_si</bpmn:outgoing>
      <bpmn:outgoing>f_cli_no</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="T_Corregir" name="Corregir y volver a correr el demo (reiterar)">
      <bpmn:documentation>Si el cliente dice no se ve bien: el agente corrige y el ciclo vuelve a T_CorrerDemo. Consistente con el loop de Gateway_Aceptado en 01-operar.</bpmn:documentation>
      <bpmn:incoming>f_cli_no</bpmn:incoming>
      <bpmn:outgoing>f_loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Citar" name="Citar la corrida en HANDOFF/CHANGELOG y git add -f (obligatorio)">
      <bpmn:incoming>f_ver_citar</bpmn:incoming>
      <bpmn:incoming>f_cli_si</bpmn:incoming>
      <bpmn:outgoing>f_citar_end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End" name="Incremento verificado con evidencia">
      <bpmn:incoming>f_citar_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="T_CorrerDemo"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_CorrerDemo" targetRef="T_Artefactos"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_Artefactos" targetRef="Gw_Tipo"/>
    <bpmn:sequenceFlow id="f_obj" name="objetivo" sourceRef="Gw_Tipo" targetRef="T_Veredicto"/>
    <bpmn:sequenceFlow id="f_subj" name="subjetivo" sourceRef="Gw_Tipo" targetRef="U_Cliente"/>
    <bpmn:sequenceFlow id="f_ver_citar" sourceRef="T_Veredicto" targetRef="T_Citar"/>
    <bpmn:sequenceFlow id="f_cli_si" name="sí: se ve bien" sourceRef="U_Cliente" targetRef="T_Citar"/>
    <bpmn:sequenceFlow id="f_cli_no" name="no: corregir" sourceRef="U_Cliente" targetRef="T_Corregir"/>
    <bpmn:sequenceFlow id="f_loop" sourceRef="T_Corregir" targetRef="T_CorrerDemo"/>
    <bpmn:sequenceFlow id="f_citar_end" sourceRef="T_Citar" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_15_Gemba">
    <bpmndi:BPMNPlane id="Plane_15_Gemba" bpmnElement="Collab_Gemba">
      <bpmndi:BPMNShape id="S_Pool" bpmnElement="Pool_Gemba" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="420"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneA" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1370" height="260"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneH" bpmnElement="Lane_Humano" isHorizontal="true">
        <dc:Bounds x="190" y="340" width="1370" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="210" y="185" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="188" y="218" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TCorrerDemo" bpmnElement="T_CorrerDemo">
        <dc:Bounds x="280" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TArtefactos" bpmnElement="T_Artefactos">
        <dc:Bounds x="490" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwTipo" bpmnElement="Gw_Tipo" isMarkerVisible="true">
        <dc:Bounds x="700" y="180" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="685" y="143" width="72" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TVeredicto" bpmnElement="T_Veredicto">
        <dc:Bounds x="800" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_UCliente" bpmnElement="U_Cliente">
        <dc:Bounds x="625" y="385" width="190" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TCorregir" bpmnElement="T_Corregir">
        <dc:Bounds x="870" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TCitar" bpmnElement="T_Citar">
        <dc:Bounds x="1100" y="170" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End" bpmnElement="End">
        <dc:Bounds x="1330" y="185" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1305" y="218" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_f1" bpmnElement="f1">
        <di:waypoint x="240" y="200"/>
        <di:waypoint x="280" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f2" bpmnElement="f2">
        <di:waypoint x="440" y="200"/>
        <di:waypoint x="490" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f3" bpmnElement="f3">
        <di:waypoint x="650" y="200"/>
        <di:waypoint x="700" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_obj" bpmnElement="f_obj">
        <di:waypoint x="740" y="200"/>
        <di:waypoint x="800" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_subj" bpmnElement="f_subj">
        <di:waypoint x="720" y="220"/>
        <di:waypoint x="720" y="385"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_ver_citar" bpmnElement="f_ver_citar">
        <di:waypoint x="960" y="200"/>
        <di:waypoint x="1100" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_cli_si" bpmnElement="f_cli_si">
        <di:waypoint x="815" y="415"/>
        <di:waypoint x="1185" y="415"/>
        <di:waypoint x="1185" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_cli_no" bpmnElement="f_cli_no">
        <di:waypoint x="720" y="385"/>
        <di:waypoint x="720" y="135"/>
        <di:waypoint x="950" y="135"/>
        <di:waypoint x="950" y="170"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_loop" bpmnElement="f_loop">
        <di:waypoint x="870" y="200"/>
        <di:waypoint x="360" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_citar_end" bpmnElement="f_citar_end">
        <di:waypoint x="1270" y="200"/>
        <di:waypoint x="1330" y="200"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
