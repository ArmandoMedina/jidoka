  <bpmn:process id="Process_QueSigue" name="/jidoka:que-sigue — priorizar el siguiente paso" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/que-sigue.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Handoff</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Handoff" name="Leer HANDOFF y decisiones pendientes">
      <bpmn:incoming>F_Start_Task_Handoff</bpmn:incoming>
      <bpmn:outgoing>F_Task_Handoff_Task_Roadmap</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Handoff" sourceRef="Start" targetRef="Task_Handoff"/>
    <bpmn:task id="Task_Roadmap" name="Leer ROADMAP">
      <bpmn:incoming>F_Task_Handoff_Task_Roadmap</bpmn:incoming>
      <bpmn:outgoing>F_Task_Roadmap_Task_Git</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Handoff_Task_Roadmap" sourceRef="Task_Handoff" targetRef="Task_Roadmap"/>
    <bpmn:serviceTask id="Task_Git" name="Revisar estado de Git">
      <bpmn:incoming>F_Task_Roadmap_Task_Git</bpmn:incoming>
      <bpmn:outgoing>F_Task_Git_Task_Separar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Roadmap_Task_Git" sourceRef="Task_Roadmap" targetRef="Task_Git"/>
    <bpmn:task id="Task_Separar" name="Separar decisiones humanas de trabajo ejecutable">
      <bpmn:incoming>F_Task_Git_Task_Separar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Separar_Task_Ordenar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Git_Task_Separar" sourceRef="Task_Git" targetRef="Task_Separar"/>
    <bpmn:task id="Task_Ordenar" name="Ordenar opciones por valor">
      <bpmn:incoming>F_Task_Separar_Task_Ordenar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Ordenar_Task_Proponer</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Separar_Task_Ordenar" sourceRef="Task_Separar" targetRef="Task_Ordenar"/>
    <bpmn:userTask id="Task_Proponer" name="Presentar recomendación y esperar">
      <bpmn:incoming>F_Task_Ordenar_Task_Proponer</bpmn:incoming>
      <bpmn:outgoing>F_Task_Proponer_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Ordenar_Task_Proponer" sourceRef="Task_Ordenar" targetRef="Task_Proponer"/>
    <bpmn:endEvent id="End" name="Siguiente paso recomendado">
      <bpmn:incoming>F_Task_Proponer_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Proponer_End" sourceRef="Task_Proponer" targetRef="End"/>
  </bpmn:process>
