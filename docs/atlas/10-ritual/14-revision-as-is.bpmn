<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_14_Revisar" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_Revisar" name="Revisar el cambio con robots y gates" isExecutable="false">
    <bpmn:documentation>Fuente: review-stop, verificar.ps1 y CI</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Diff</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Diff" name="Preparar el diff revisable">
      <bpmn:incoming>F_Start_Task_Diff</bpmn:incoming>
      <bpmn:outgoing>F_Task_Diff_Task_CodeReview</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Diff" sourceRef="Start" targetRef="Task_Diff"/>
    <bpmn:serviceTask id="Task_CodeReview" name="Ejecutar revisión de código">
      <bpmn:incoming>F_Task_Diff_Task_CodeReview</bpmn:incoming>
      <bpmn:outgoing>F_Task_CodeReview_Task_Hallazgos</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Diff_Task_CodeReview" sourceRef="Task_Diff" targetRef="Task_CodeReview"/>
    <bpmn:task id="Task_Hallazgos" name="Atender o registrar hallazgos">
      <bpmn:incoming>F_Task_CodeReview_Task_Hallazgos</bpmn:incoming>
      <bpmn:outgoing>F_Task_Hallazgos_Task_Docs</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_CodeReview_Task_Hallazgos" sourceRef="Task_CodeReview" targetRef="Task_Hallazgos"/>
    <bpmn:task id="Task_Docs" name="Sincronizar documentos dueños">
      <bpmn:incoming>F_Task_Hallazgos_Task_Docs</bpmn:incoming>
      <bpmn:outgoing>F_Task_Docs_Task_Gates</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Hallazgos_Task_Docs" sourceRef="Task_Hallazgos" targetRef="Task_Docs"/>
    <bpmn:serviceTask id="Task_Gates" name="Ejecutar gates aplicables">
      <bpmn:incoming>F_Task_Docs_Task_Gates</bpmn:incoming>
      <bpmn:outgoing>F_Task_Gates_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Docs_Task_Gates" sourceRef="Task_Docs" targetRef="Task_Gates"/>
    <bpmn:endEvent id="End" name="Cambio revisado y listo para Gemba">
      <bpmn:incoming>F_Task_Gates_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Gates_End" sourceRef="Task_Gates" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_14_Revisar">
    <bpmndi:BPMNPlane id="Plane_Diagram_14_Revisar" bpmnElement="Process_Revisar">
