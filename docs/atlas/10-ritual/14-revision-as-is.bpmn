      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_CodeReview_Task_Hallazgos" bpmnElement="F_Task_CodeReview_Task_Hallazgos">
        <di:waypoint x="580" y="238"/>
        <di:waypoint x="640" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Docs" bpmnElement="Task_Docs">
        <dc:Bounds x="870" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Hallazgos_Task_Docs" bpmnElement="F_Task_Hallazgos_Task_Docs">
        <di:waypoint x="810" y="238"/>
        <di:waypoint x="870" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Gates" bpmnElement="Task_Gates">
        <dc:Bounds x="1100" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Docs_Task_Gates" bpmnElement="F_Task_Docs_Task_Gates">
        <di:waypoint x="1040" y="238"/>
        <di:waypoint x="1100" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_End" bpmnElement="End">
        <dc:Bounds x="1330" y="220" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Gates_End" bpmnElement="F_Task_Gates_End">
        <di:waypoint x="1270" y="238"/>
