        <di:waypoint x="870" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_No" bpmnElement="F_No">
        <di:waypoint x="895" y="263"/>
        <di:waypoint x="895" y="370"/>
        <di:waypoint x="1000" y="370"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Diag_Impl" bpmnElement="F_Diag_Impl">
