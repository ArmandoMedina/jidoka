<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_13_Construye" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2">
  <bpmn:process id="Process_Construye" name="Construir una rebanada vertical" isExecutable="false">
    <bpmn:documentation>Fuente: kanban/lazo.md y ritual de sprint</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Rebanada aprobada">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Seleccionar" name="Seleccionar la siguiente rebanada">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Implementar" name="Implementar el cambio">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
      <bpmn:incoming>F_Diag_Impl</bpmn:incoming>
    </bpmn:task>
    <bpmn:serviceTask id="Task_Verificar" name="Ejecutar tests y verificaciones aplicables">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Verde" name="¿Quedó verde?">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F_No</bpmn:outgoing>
      <bpmn:outgoing>F_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Diagnosticar" name="Diagnosticar el rojo">
      <bpmn:incoming>F_No</bpmn:incoming>
      <bpmn:outgoing>F_Diag_Impl</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Commit" name="Consolidar la rebanada en un commit">
      <bpmn:incoming>F_Si</bpmn:incoming>
      <bpmn:outgoing>F_Commit_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End" name="Rebanada construida y verde">
      <bpmn:incoming>F_Commit_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="Task_Seleccionar"/>
    <bpmn:sequenceFlow id="F2" sourceRef="Task_Seleccionar" targetRef="Task_Implementar"/>
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Implementar" targetRef="Task_Verificar"/>
    <bpmn:sequenceFlow id="F4" sourceRef="Task_Verificar" targetRef="Gateway_Verde"/>
    <bpmn:sequenceFlow id="F_No" sourceRef="Gateway_Verde" targetRef="Task_Diagnosticar" name="No"/>
    <bpmn:sequenceFlow id="F_Diag_Impl" sourceRef="Task_Diagnosticar" targetRef="Task_Implementar"/>
    <bpmn:sequenceFlow id="F_Si" sourceRef="Gateway_Verde" targetRef="Task_Commit" name="Sí"/>
    <bpmn:sequenceFlow id="F_Commit_End" sourceRef="Task_Commit" targetRef="End"/>
  </bpmn:process>
