  <bpmn:process id="Process_Descubre" name="/jidoka:descubre — descubrir el QUÉ" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/descubre.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Inyectar</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Inyectar" name="Leer e inyectar el brief existente">
      <bpmn:incoming>F_Start_Task_Inyectar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Inyectar_Task_Diagnosticar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Inyectar" sourceRef="Start" targetRef="Task_Inyectar"/>
    <bpmn:task id="Task_Diagnosticar" name="Diagnosticar tipo de niebla y autoridad">
      <bpmn:incoming>F_Task_Inyectar_Task_Diagnosticar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Diagnosticar_Task_Entrevistar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Inyectar_Task_Diagnosticar" sourceRef="Task_Inyectar" targetRef="Task_Diagnosticar"/>
    <bpmn:userTask id="Task_Entrevistar" name="Entrevistar con hechos pasados">
      <bpmn:incoming>F_Task_Diagnosticar_Task_Entrevistar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Entrevistar_Task_Kit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Diagnosticar_Task_Entrevistar" sourceRef="Task_Diagnosticar" targetRef="Task_Entrevistar"/>
    <bpmn:task id="Task_Kit" name="Preparar kit portátil si la autoridad es externa">
      <bpmn:incoming>F_Task_Entrevistar_Task_Kit</bpmn:incoming>
      <bpmn:outgoing>F_Task_Kit_Task_Poblar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Entrevistar_Task_Kit" sourceRef="Task_Entrevistar" targetRef="Task_Kit"/>
    <bpmn:task id="Task_Poblar" name="Poblar el brief sin inventar huecos">
      <bpmn:incoming>F_Task_Kit_Task_Poblar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Poblar_Task_Aprobar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Kit_Task_Poblar" sourceRef="Task_Kit" targetRef="Task_Poblar"/>
    <bpmn:userTask id="Task_Aprobar" name="Obtener aprobación nombrada">
      <bpmn:incoming>F_Task_Poblar_Task_Aprobar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Aprobar_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Poblar_Task_Aprobar" sourceRef="Task_Poblar" targetRef="Task_Aprobar"/>
    <bpmn:endEvent id="End" name="QUÉ aprobado o brief en definición">
      <bpmn:incoming>F_Task_Aprobar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Aprobar_End" sourceRef="Task_Aprobar" targetRef="End"/>
  </bpmn:process>
