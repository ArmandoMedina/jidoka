<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_18_Desatendido" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collab_Desatendido">
    <bpmn:participant id="Pool_Desatendido" name="/jidoka:desatendido — pase autónomo, dos lanes" processRef="Process_Desatendido"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Desatendido" name="/jidoka:desatendido — repartir lo ejecutable de lo que exige juicio" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/desatendido.md. Carriles: el Agente ejecuta lo mecánico y reversible; lo de juicio/irreversible se DEJA LISTO para el Humano (no se ejecuta).</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Desatendido">
      <bpmn:lane id="Lane_Agente" name="Agente (ejecuta lo autorizado)">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Rama</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Reconocer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Repartir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Ejecutar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Complica</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Cierre</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Humano" name="Humano (lo deja listo, no lo ejecuta)">
        <bpmn:flowNodeRef>U_DejarListo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Pase autónomo (sin humano)">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Rama" name="Rama dedicada (auto/fecha); nada toca main">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Reconocer" name="Reconocer: inventariar lo sano, confirmar/refutar pistas">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Repartir" name="Repartir en 2 lanes por prioridad (seguridad > corrección > ...)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:textAnnotation id="Ann_NoGates">
      <bpmn:text>REGLA DURA: NO edites tus propios gates (blast-radius.json, hooks, CI). Un cambio a estos va siempre a la lane [humano] como borrador, nunca al [agente].</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_NoGates" sourceRef="Ann_NoGates" targetRef="T_Repartir"/>
    <bpmn:task id="T_Ejecutar" name="Ejecutar lo mecánico/reversible/autorizado (cada uno verde)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Complica" name="¿Se complica o sorprende? (click-it-down)">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f_si</bpmn:outgoing>
      <bpmn:outgoing>f_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="U_DejarListo" name="Dejar listo lo de juicio/irreversible/credenciales (NO ejecutar)">
      <bpmn:incoming>f_si</bpmn:incoming>
      <bpmn:outgoing>f_listo_cierre</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="T_Cierre" name="Cierre: lo durable a su doc dueño; lane [humano] corta y priorizada arriba">
      <bpmn:incoming>f_no</bpmn:incoming>
      <bpmn:incoming>f_listo_cierre</bpmn:incoming>
      <bpmn:outgoing>f_cierre_end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End" name="Pase cerrado; lane [humano] lista para el regreso">
      <bpmn:incoming>f_cierre_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="T_Rama"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_Rama" targetRef="T_Reconocer"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_Reconocer" targetRef="T_Repartir"/>
    <bpmn:sequenceFlow id="f4" sourceRef="T_Repartir" targetRef="T_Ejecutar"/>
    <bpmn:sequenceFlow id="f5" sourceRef="T_Ejecutar" targetRef="Gw_Complica"/>
    <bpmn:sequenceFlow id="f_si" name="sí: baja (deja preparado)" sourceRef="Gw_Complica" targetRef="U_DejarListo"/>
    <bpmn:sequenceFlow id="f_no" name="no" sourceRef="Gw_Complica" targetRef="T_Cierre"/>
    <bpmn:sequenceFlow id="f_listo_cierre" sourceRef="U_DejarListo" targetRef="T_Cierre"/>
    <bpmn:sequenceFlow id="f_cierre_end" sourceRef="T_Cierre" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_18_Desatendido">
    <bpmndi:BPMNPlane id="Plane_18_Desatendido" bpmnElement="Collab_Desatendido">
      <bpmndi:BPMNShape id="S_Pool" bpmnElement="Pool_Desatendido" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1440" height="400"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneA" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1410" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneH" bpmnElement="Lane_Humano" isHorizontal="true">
        <dc:Bounds x="190" y="330" width="1410" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="210" y="185" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="186" y="218" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TRama" bpmnElement="T_Rama">
        <dc:Bounds x="280" y="170" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TReconocer" bpmnElement="T_Reconocer">
        <dc:Bounds x="480" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TRepartir" bpmnElement="T_Repartir">
        <dc:Bounds x="690" y="170" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TEjecutar" bpmnElement="T_Ejecutar">
        <dc:Bounds x="900" y="170" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwComplica" bpmnElement="Gw_Complica" isMarkerVisible="true">
        <dc:Bounds x="1120" y="180" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1105" y="143" width="72" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_UDejarListo" bpmnElement="U_DejarListo">
        <dc:Bounds x="1030" y="375" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TCierre" bpmnElement="T_Cierre">
        <dc:Bounds x="1250" y="170" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End" bpmnElement="End">
        <dc:Bounds x="1500" y="185" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1475" y="218" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_f1" bpmnElement="f1">
        <di:waypoint x="240" y="200"/>
        <di:waypoint x="280" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f2" bpmnElement="f2">
        <di:waypoint x="430" y="200"/>
        <di:waypoint x="480" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f3" bpmnElement="f3">
        <di:waypoint x="640" y="200"/>
        <di:waypoint x="690" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f4" bpmnElement="f4">
        <di:waypoint x="850" y="200"/>
        <di:waypoint x="900" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f5" bpmnElement="f5">
        <di:waypoint x="1070" y="200"/>
        <di:waypoint x="1120" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_si" bpmnElement="f_si">
        <di:waypoint x="1140" y="220"/>
        <di:waypoint x="1140" y="375"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_no" bpmnElement="f_no">
        <di:waypoint x="1160" y="200"/>
        <di:waypoint x="1250" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_listo_cierre" bpmnElement="f_listo_cierre">
        <di:waypoint x="1230" y="405"/>
        <di:waypoint x="1335" y="405"/>
        <di:waypoint x="1335" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_cierre_end" bpmnElement="f_cierre_end">
        <di:waypoint x="1420" y="200"/>
        <di:waypoint x="1500" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="S_AnnNoGates" bpmnElement="Ann_NoGates">
        <dc:Bounds x="650" y="90" width="310" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_Assoc_NoGates" bpmnElement="Assoc_NoGates">
        <di:waypoint x="770" y="150"/>
        <di:waypoint x="770" y="170"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
