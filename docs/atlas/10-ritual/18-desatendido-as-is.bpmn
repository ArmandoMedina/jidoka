  <bpmn:process id="Process_Desatendido" name="/jidoka:desatendido — trabajo sin humano presente" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/desatendido.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Rama</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Rama" name="Crear rama dedicada y reconocer estado">
      <bpmn:incoming>F_Start_Task_Rama</bpmn:incoming>
      <bpmn:outgoing>F_Task_Rama_Task_Clasificar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Rama" sourceRef="Start" targetRef="Task_Rama"/>
    <bpmn:task id="Task_Clasificar" name="Separar lane agente y lane humano">
      <bpmn:incoming>F_Task_Rama_Task_Clasificar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Clasificar_Task_Ejecutar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Rama_Task_Clasificar" sourceRef="Task_Rama" targetRef="Task_Clasificar"/>
    <bpmn:serviceTask id="Task_Ejecutar" name="Ejecutar solo trabajo reversible autorizado">
      <bpmn:incoming>F_Task_Clasificar_Task_Ejecutar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Ejecutar_Task_ClickDown</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Clasificar_Task_Ejecutar" sourceRef="Task_Clasificar" targetRef="Task_Ejecutar"/>
    <bpmn:task id="Task_ClickDown" name="Bajar automatización ante sorpresa">
      <bpmn:incoming>F_Task_Ejecutar_Task_ClickDown</bpmn:incoming>
      <bpmn:outgoing>F_Task_ClickDown_Task_Cerrar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Ejecutar_Task_ClickDown" sourceRef="Task_Ejecutar" targetRef="Task_ClickDown"/>
    <bpmn:task id="Task_Cerrar" name="Registrar evidencia y pendientes humanos">
      <bpmn:incoming>F_Task_ClickDown_Task_Cerrar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Cerrar_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_ClickDown_Task_Cerrar" sourceRef="Task_ClickDown" targetRef="Task_Cerrar"/>
    <bpmn:endEvent id="End" name="Trabajo reversible ejecutado; juicio pendiente preparado">
      <bpmn:incoming>F_Task_Cerrar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Cerrar_End" sourceRef="Task_Cerrar" targetRef="End"/>
  </bpmn:process>
