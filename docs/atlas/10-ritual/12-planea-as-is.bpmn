      <bpmndi:BPMNShape id="Shape_Gateway_Claro" bpmnElement="Gateway_Claro" isMarkerVisible="true">
        <dc:Bounds x="410" y="213" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_Descubre" bpmnElement="Call_Descubre">
        <dc:Bounds x="540" y="330" width="190" height="82"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Annotation_Call_Descubre" bpmnElement="Annotation_Call_Descubre">
        <dc:Bounds x="540" y="428" width="220" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Association_Annotation_Call_Descubre" bpmnElement="Association_Annotation_Call_Descubre">
        <di:waypoint x="650.0" y="428"/>
        <di:waypoint x="650.0" y="418"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Criterios" bpmnElement="Task_Criterios">
        <dc:Bounds x="540" y="140" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Stop" bpmnElement="Task_Stop">
        <dc:Bounds x="780" y="140" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Aprob" bpmnElement="Gateway_Aprob" isMarkerVisible="true">
        <dc:Bounds x="1020" y="155" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_No" bpmnElement="End_No">
        <dc:Bounds x="1160" y="60" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Plan" bpmnElement="Task_Plan">
        <dc:Bounds x="1160" y="210" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Archivar" bpmnElement="Task_Archivar">
        <dc:Bounds x="1390" y="210" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Si" bpmnElement="End_Si">
        <dc:Bounds x="1630" y="233" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F1" bpmnElement="F1">
        <di:waypoint x="116" y="238"/>
        <di:waypoint x="180" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F2" bpmnElement="F2">
        <di:waypoint x="350" y="238"/>
        <di:waypoint x="410" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_NoClaro" bpmnElement="F_NoClaro">
        <di:waypoint x="435" y="263"/>
        <di:waypoint x="435" y="371"/>
        <di:waypoint x="540" y="371"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Desc_Crit" bpmnElement="F_Desc_Crit">
        <di:waypoint x="730" y="371"/>
        <di:waypoint x="750" y="371"/>
        <di:waypoint x="750" y="100"/>
        <di:waypoint x="625" y="100"/>
        <di:waypoint x="625" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Claro" bpmnElement="F_Claro">
