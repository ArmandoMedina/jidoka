        <di:waypoint x="1035" y="330"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Inspeccionar" bpmnElement="Task_Inspeccionar">
        <dc:Bounds x="1180" y="540" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Rutear" bpmnElement="Task_Rutear">
        <dc:Bounds x="1380" y="540" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Delimitar" bpmnElement="Task_Delimitar">
        <dc:Bounds x="1580" y="308" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Contexto" bpmnElement="Gateway_Contexto" isMarkerVisible="true">
        <dc:Bounds x="1780" y="318" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Send_Aclarar" bpmnElement="Send_Aclarar">
        <dc:Bounds x="1880" y="220" width="150" height="60"/>
      </bpmndi:BPMNShape>
