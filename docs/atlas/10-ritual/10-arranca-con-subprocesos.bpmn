<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_10_Arranca" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3">
  <bpmn:collaboration id="Collaboration_10_Arranca">
    <bpmn:participant id="Participant_Usuario" name="Usuario"/>
    <bpmn:participant id="Participant_Proyecto" name="/jidoka:arranca — abrir y orientar la sesión (sin construir)" processRef="Process_Arranca"/>
    <bpmn:messageFlow id="MF_Start" sourceRef="Participant_Usuario" targetRef="Start_Arranque" name="/jidoka:arranca" messageRef="Message_Arranque"/>
    <bpmn:messageFlow id="MF_Orient" sourceRef="Send_Orientar" targetRef="Participant_Usuario" name="Orientación" messageRef="Message_Orientacion"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Arranca" name="/jidoka:arranca — abrir y orientar la sesión" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/arranca.md. Las 6 secciones del comando en orden: §1 leer el estado en vuelo (HANDOFF, PRODUCT_BRIEF, infra/roster, CONTRIBUTING, plan del día, git), §2 roster + router (rutear.ps1), §3 el asiento lo ocupa el subagente, §4 desconfía de la compactación (guarda transversal, anotación), §5 fija las reglas duras, §6 orienta y espera la señal del cliente. El STOP final es la señal del cliente antes de construir.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_10_Arranca">
      <bpmn:lane id="Lane_Agente" name="Agente orquestador">
        <bpmn:flowNodeRef>Start_Arranque</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Leer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Router</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Asiento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Reglas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Orientar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Sprint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Planea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Rebanada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Orientar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Humano" name="Humano (cliente)">
        <bpmn:flowNodeRef>U_Senal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Orientada</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Arranque" name="Solicitud /jidoka:arranca recibida">
      <bpmn:messageEventDefinition id="MED_Start_Arranque" messageRef="Message_Arranque"/>
      <bpmn:outgoing>F_Start_Leer</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_Leer" name="1. Leer el estado en vuelo: HANDOFF, PRODUCT_BRIEF, infra (roster/casting), CONTRIBUTING, plan del día, git">
      <bpmn:incoming>F_Start_Leer</bpmn:incoming>
      <bpmn:outgoing>F_Leer_Router</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Router" name="2. Ubicar el roster y correr el router (rutear.ps1): preview de gates">
      <bpmn:incoming>F_Leer_Router</bpmn:incoming>
      <bpmn:outgoing>F_Router_Asiento</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="T_Asiento" name="3. El asiento lo ocupa el subagente: elegir a quién delegar (el tier ya está fijo)">
      <bpmn:incoming>F_Router_Asiento</bpmn:incoming>
      <bpmn:outgoing>F_Asiento_Reglas</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Reglas" name="5. Fijar y enunciar las reglas duras de la sesión">
      <bpmn:incoming>F_Asiento_Reglas</bpmn:incoming>
      <bpmn:outgoing>F_Reglas_Orientar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Orientar" name="6. Orientar: resumir dónde estamos y qué sigue en orden de valor">
      <bpmn:incoming>F_Reglas_Orientar</bpmn:incoming>
      <bpmn:outgoing>F_Orientar_G</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Sprint" name="¿La tarea amerita un sprint?">
      <bpmn:incoming>F_Orientar_G</bpmn:incoming>
      <bpmn:outgoing>F_G_Si</bpmn:outgoing>
      <bpmn:outgoing>F_G_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Planea" name="Proponer /jidoka:planea (el QUÉ aprobado antes del código)">
      <bpmn:incoming>F_G_Si</bpmn:incoming>
      <bpmn:outgoing>F_Planea_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Rebanada" name="Proponer la rebanada o acción acotada directa">
      <bpmn:incoming>F_G_No</bpmn:incoming>
      <bpmn:outgoing>F_Rebanada_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Join">
      <bpmn:incoming>F_Planea_Join</bpmn:incoming>
      <bpmn:incoming>F_Rebanada_Join</bpmn:incoming>
      <bpmn:outgoing>F_Join_Orient</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Send_Orientar" name="Presentar orientación al cliente" messageRef="Message_Orientacion">
      <bpmn:incoming>F_Join_Orient</bpmn:incoming>
      <bpmn:outgoing>F_Orient_Senal</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="U_Senal" name="STOP: el cliente da la señal — el agente no arranca a construir solo">
      <bpmn:incoming>F_Orient_Senal</bpmn:incoming>
      <bpmn:outgoing>F_Senal_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Orientada" name="Sesión orientada; construcción NO iniciada sin el QUÉ aprobado">
      <bpmn:incoming>F_Senal_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_Leer" sourceRef="Start_Arranque" targetRef="T_Leer"/>
    <bpmn:sequenceFlow id="F_Leer_Router" sourceRef="T_Leer" targetRef="T_Router"/>
    <bpmn:sequenceFlow id="F_Router_Asiento" sourceRef="T_Router" targetRef="T_Asiento"/>
    <bpmn:sequenceFlow id="F_Asiento_Reglas" sourceRef="T_Asiento" targetRef="T_Reglas"/>
    <bpmn:sequenceFlow id="F_Reglas_Orientar" sourceRef="T_Reglas" targetRef="T_Orientar"/>
    <bpmn:sequenceFlow id="F_Orientar_G" sourceRef="T_Orientar" targetRef="Gw_Sprint"/>
    <bpmn:sequenceFlow id="F_G_Si" sourceRef="Gw_Sprint" targetRef="T_Planea" name="sí"/>
    <bpmn:sequenceFlow id="F_G_No" sourceRef="Gw_Sprint" targetRef="T_Rebanada" name="no"/>
    <bpmn:sequenceFlow id="F_Planea_Join" sourceRef="T_Planea" targetRef="Gw_Join"/>
    <bpmn:sequenceFlow id="F_Rebanada_Join" sourceRef="T_Rebanada" targetRef="Gw_Join"/>
    <bpmn:sequenceFlow id="F_Join_Orient" sourceRef="Gw_Join" targetRef="Send_Orientar"/>
    <bpmn:sequenceFlow id="F_Orient_Senal" sourceRef="Send_Orientar" targetRef="U_Senal"/>
    <bpmn:sequenceFlow id="F_Senal_End" sourceRef="U_Senal" targetRef="End_Orientada"/>
    <bpmn:textAnnotation id="Ann_Compactacion">
      <bpmn:text>GUARDA §4 — desconfía de la compactación: verifica el HANDOFF y el plan activo contra el artefacto real, no contra el resumen, antes de concluir. La compactación puede borrar pistas activas.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Compactacion" sourceRef="Ann_Compactacion" targetRef="T_Leer"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_10_Arranca">
    <bpmndi:BPMNPlane id="Plane_Diagram_10_Arranca" bpmnElement="Collaboration_10_Arranca">
      <bpmndi:BPMNShape id="Shape_Participant_Usuario" bpmnElement="Participant_Usuario" isHorizontal="true">
        <dc:Bounds x="200" y="80" width="2040" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Participant_Proyecto" bpmnElement="Participant_Proyecto" isHorizontal="true">
        <dc:Bounds x="200" y="170" width="2040" height="400"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Agente" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="230" y="170" width="2010" height="280"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Humano" bpmnElement="Lane_Humano" isHorizontal="true">
        <dc:Bounds x="230" y="450" width="2010" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Start_Arranque" bpmnElement="Start_Arranque">
        <dc:Bounds x="250" y="295" width="30" height="30"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="238" y="328" width="70" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Leer" bpmnElement="T_Leer">
        <dc:Bounds x="330" y="280" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Router" bpmnElement="T_Router">
        <dc:Bounds x="530" y="280" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Asiento" bpmnElement="T_Asiento">
        <dc:Bounds x="730" y="280" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Reglas" bpmnElement="T_Reglas">
        <dc:Bounds x="930" y="280" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Orientar" bpmnElement="T_Orientar">
        <dc:Bounds x="1130" y="280" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gw_Sprint" bpmnElement="Gw_Sprint" isMarkerVisible="true">
        <dc:Bounds x="1330" y="290" width="40" height="40"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1300" y="253" width="100" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Planea" bpmnElement="T_Planea">
        <dc:Bounds x="1440" y="195" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_T_Rebanada" bpmnElement="T_Rebanada">
        <dc:Bounds x="1440" y="365" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gw_Join" bpmnElement="Gw_Join" isMarkerVisible="true">
        <dc:Bounds x="1670" y="290" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Send_Orientar" bpmnElement="Send_Orientar">
        <dc:Bounds x="1770" y="280" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_U_Senal" bpmnElement="U_Senal">
        <dc:Bounds x="1770" y="480" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Orientada" bpmnElement="End_Orientada">
        <dc:Bounds x="2020" y="495" width="30" height="30"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1998" y="528" width="80" height="40"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Start_Leer" bpmnElement="F_Start_Leer">
        <di:waypoint x="280" y="310"/>
        <di:waypoint x="330" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Leer_Router" bpmnElement="F_Leer_Router">
        <di:waypoint x="480" y="310"/>
        <di:waypoint x="530" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Router_Asiento" bpmnElement="F_Router_Asiento">
        <di:waypoint x="680" y="310"/>
        <di:waypoint x="730" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Asiento_Reglas" bpmnElement="F_Asiento_Reglas">
        <di:waypoint x="880" y="310"/>
        <di:waypoint x="930" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Reglas_Orientar" bpmnElement="F_Reglas_Orientar">
        <di:waypoint x="1080" y="310"/>
        <di:waypoint x="1130" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Orientar_G" bpmnElement="F_Orientar_G">
        <di:waypoint x="1280" y="310"/>
        <di:waypoint x="1330" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_G_Si" bpmnElement="F_G_Si">
        <di:waypoint x="1350" y="290"/>
        <di:waypoint x="1350" y="225"/>
        <di:waypoint x="1440" y="225"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1360" y="248" width="20" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_G_No" bpmnElement="F_G_No">
        <di:waypoint x="1350" y="330"/>
        <di:waypoint x="1350" y="395"/>
        <di:waypoint x="1440" y="395"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1358" y="355" width="20" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Planea_Join" bpmnElement="F_Planea_Join">
        <di:waypoint x="1610" y="225"/>
        <di:waypoint x="1690" y="225"/>
        <di:waypoint x="1690" y="290"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Rebanada_Join" bpmnElement="F_Rebanada_Join">
        <di:waypoint x="1610" y="395"/>
        <di:waypoint x="1690" y="395"/>
        <di:waypoint x="1690" y="330"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Join_Orient" bpmnElement="F_Join_Orient">
        <di:waypoint x="1710" y="310"/>
        <di:waypoint x="1770" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Orient_Senal" bpmnElement="F_Orient_Senal">
        <di:waypoint x="1850" y="340"/>
        <di:waypoint x="1850" y="480"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Senal_End" bpmnElement="F_Senal_End">
        <di:waypoint x="1930" y="510"/>
        <di:waypoint x="2020" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MF_Start" bpmnElement="MF_Start">
        <di:waypoint x="265" y="140"/>
        <di:waypoint x="265" y="295"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MF_Orient" bpmnElement="MF_Orient">
        <di:waypoint x="1850" y="280"/>
        <di:waypoint x="1850" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Ann_Compactacion" bpmnElement="Ann_Compactacion">
        <dc:Bounds x="330" y="180" width="360" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Assoc_Compactacion" bpmnElement="Assoc_Compactacion">
        <di:waypoint x="450" y="250"/>
        <di:waypoint x="430" y="280"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
  <bpmn:message id="Message_Arranque" name="Solicitud /jidoka:arranca"/>
  <bpmn:message id="Message_Orientacion" name="Orientación de sesión"/>
</bpmn:definitions>
