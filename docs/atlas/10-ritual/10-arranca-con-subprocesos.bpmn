<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_10_Arranca" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collaboration_10_Arranca">
    <bpmn:participant id="Participant_Usuario" name="Usuario"/>
    <bpmn:participant id="Participant_Proyecto" name="Proyecto gobernado con Jidoka" processRef="Process_Arranca"/>
    <bpmn:messageFlow id="MF_Start" sourceRef="Participant_Usuario" targetRef="Start_Arranque" name="/jidoka:arranca" messageRef="Message_Arranque"/>
    <bpmn:messageFlow id="MF_Aclarar" sourceRef="Send_Aclarar" targetRef="Participant_Usuario" name="Aclaración" messageRef="Message_Aclaracion"/>
    <bpmn:messageFlow id="MF_Respuesta" sourceRef="Participant_Usuario" targetRef="Catch_Respuesta" name="Respuesta" messageRef="Message_Respuesta"/>
    <bpmn:messageFlow id="MF_Orient" sourceRef="Send_Orientar" targetRef="Participant_Usuario" name="Orientación" messageRef="Message_Orientacion"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Arranca" name="/jidoka:arranca — abrir y orientar la sesión" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/arranca.md. Subprocesos EXPANDIDOS en el lienzo (sin drill-down): el detalle se ve aquí mismo.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_10_Arranca">
      <bpmn:lane id="Lane_Agente" name="Agente orquestador">
        <bpmn:flowNodeRef>Start_Arranque</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_RecuperarContexto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Delimitar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Contexto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Aclarar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_Respuesta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_DeterminarSiguiente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Orientar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Orientada</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Motor" name="Motor Jidoka / repositorio">
        <bpmn:flowNodeRef>Task_Inspeccionar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Rutear</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Arranque" name="Solicitud de arranque recibida">
      <bpmn:messageEventDefinition id="MED_Start_Arranque" messageRef="Message_Arranque"/>
      <bpmn:outgoing>F_Start_Ctx</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:subProcess id="Sub_RecuperarContexto" name="Recuperar contexto mínimo" triggeredByEvent="false">
      <bpmn:startEvent id="Ctx_Start" name="Contexto requerido">
        <bpmn:outgoing>Ctx_F1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:task id="Ctx_HANDOFF" name="Leer HANDOFF.md">
        <bpmn:incoming>Ctx_F1</bpmn:incoming>
        <bpmn:outgoing>Ctx_F2</bpmn:outgoing>
      </bpmn:task>
      <bpmn:task id="Ctx_Recursos" name="Leer recursos y casting">
        <bpmn:incoming>Ctx_F2</bpmn:incoming>
        <bpmn:outgoing>Ctx_F3</bpmn:outgoing>
      </bpmn:task>
      <bpmn:exclusiveGateway id="Ctx_Activo" name="¿Hay retoma o plan activo?">
        <bpmn:incoming>Ctx_F3</bpmn:incoming>
        <bpmn:outgoing>Ctx_F_Si</bpmn:outgoing>
        <bpmn:outgoing>Ctx_F_No</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:task id="Ctx_Plan" name="Leer plan activo y referencias de retoma">
        <bpmn:incoming>Ctx_F_Si</bpmn:incoming>
        <bpmn:outgoing>Ctx_F_Plan</bpmn:outgoing>
      </bpmn:task>
      <bpmn:exclusiveGateway id="Ctx_Join">
        <bpmn:incoming>Ctx_F_Plan</bpmn:incoming>
        <bpmn:incoming>Ctx_F_No</bpmn:incoming>
        <bpmn:outgoing>Ctx_F_End</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Ctx_End" name="Contexto mínimo recuperado">
        <bpmn:incoming>Ctx_F_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Ctx_F1" sourceRef="Ctx_Start" targetRef="Ctx_HANDOFF"/>
      <bpmn:sequenceFlow id="Ctx_F2" sourceRef="Ctx_HANDOFF" targetRef="Ctx_Recursos"/>
      <bpmn:sequenceFlow id="Ctx_F3" sourceRef="Ctx_Recursos" targetRef="Ctx_Activo"/>
      <bpmn:sequenceFlow id="Ctx_F_Si" sourceRef="Ctx_Activo" targetRef="Ctx_Plan" name="Sí"/>
      <bpmn:sequenceFlow id="Ctx_F_Plan" sourceRef="Ctx_Plan" targetRef="Ctx_Join"/>
      <bpmn:sequenceFlow id="Ctx_F_No" sourceRef="Ctx_Activo" targetRef="Ctx_Join" name="No"/>
      <bpmn:sequenceFlow id="Ctx_F_End" sourceRef="Ctx_Join" targetRef="Ctx_End"/>
      <bpmn:incoming>F_Start_Ctx</bpmn:incoming>
      <bpmn:outgoing>F_Ctx_Inspect</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:serviceTask id="Task_Inspeccionar" name="Inspeccionar Git y estado del motor">
      <bpmn:incoming>F_Ctx_Inspect</bpmn:incoming>
      <bpmn:outgoing>F_Inspect_Router</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Rutear" name="Ejecutar router de áreas, roles y gates">
      <bpmn:incoming>F_Inspect_Router</bpmn:incoming>
      <bpmn:outgoing>F_Router_Delim</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_Delimitar" name="Delimitar objetivo y situación de la sesión">
      <bpmn:incoming>F_Router_Delim</bpmn:incoming>
      <bpmn:outgoing>F_Delim_G</bpmn:outgoing>
      <bpmn:incoming>F_Resp_Delim</bpmn:incoming>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Contexto" name="¿Falta contexto crítico?">
      <bpmn:incoming>F_Delim_G</bpmn:incoming>
      <bpmn:outgoing>F_G_Si</bpmn:outgoing>
      <bpmn:outgoing>F_G_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Send_Aclarar" name="Solicitar aclaración al usuario" messageRef="Message_Aclaracion">
      <bpmn:incoming>F_G_Si</bpmn:incoming>
      <bpmn:outgoing>F_Aclarar_Resp</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_Respuesta" name="Respuesta recibida">
      <bpmn:messageEventDefinition id="MED_Respuesta" messageRef="Message_Respuesta"/>
      <bpmn:incoming>F_Aclarar_Resp</bpmn:incoming>
      <bpmn:outgoing>F_Resp_Delim</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:subProcess id="Sub_DeterminarSiguiente" name="Determinar siguiente paso" triggeredByEvent="false">
      <bpmn:startEvent id="Next_Start" name="Situación delimitada">
        <bpmn:outgoing>Next_F1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:task id="Next_Docs" name="Leer solo documentación activada">
        <bpmn:incoming>Next_F1</bpmn:incoming>
        <bpmn:outgoing>Next_F2</bpmn:outgoing>
      </bpmn:task>
      <bpmn:task id="Next_Eval" name="Evaluar tamaño, valor y riesgo">
        <bpmn:incoming>Next_F2</bpmn:incoming>
        <bpmn:outgoing>Next_F3</bpmn:outgoing>
      </bpmn:task>
      <bpmn:exclusiveGateway id="Next_Plan" name="¿Requiere plan aprobado?">
        <bpmn:incoming>Next_F3</bpmn:incoming>
        <bpmn:outgoing>Next_Si</bpmn:outgoing>
        <bpmn:outgoing>Next_No</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:task id="Next_Recomendar" name="Recomendar /jidoka:planea">
        <bpmn:incoming>Next_Si</bpmn:incoming>
        <bpmn:outgoing>Next_Rec_Join</bpmn:outgoing>
      </bpmn:task>
      <bpmn:task id="Next_Accion" name="Preparar siguiente acción acotada">
        <bpmn:incoming>Next_No</bpmn:incoming>
        <bpmn:outgoing>Next_Acc_Join</bpmn:outgoing>
      </bpmn:task>
      <bpmn:exclusiveGateway id="Next_Join">
        <bpmn:incoming>Next_Rec_Join</bpmn:incoming>
        <bpmn:incoming>Next_Acc_Join</bpmn:incoming>
        <bpmn:outgoing>Next_Join_End</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Next_End" name="Siguiente paso formulado">
        <bpmn:incoming>Next_Join_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Next_F1" sourceRef="Next_Start" targetRef="Next_Docs"/>
      <bpmn:sequenceFlow id="Next_F2" sourceRef="Next_Docs" targetRef="Next_Eval"/>
      <bpmn:sequenceFlow id="Next_F3" sourceRef="Next_Eval" targetRef="Next_Plan"/>
      <bpmn:sequenceFlow id="Next_Si" sourceRef="Next_Plan" targetRef="Next_Recomendar" name="Sí"/>
      <bpmn:sequenceFlow id="Next_No" sourceRef="Next_Plan" targetRef="Next_Accion" name="No"/>
      <bpmn:sequenceFlow id="Next_Rec_Join" sourceRef="Next_Recomendar" targetRef="Next_Join"/>
      <bpmn:sequenceFlow id="Next_Acc_Join" sourceRef="Next_Accion" targetRef="Next_Join"/>
      <bpmn:sequenceFlow id="Next_Join_End" sourceRef="Next_Join" targetRef="Next_End"/>
      <bpmn:incoming>F_G_No</bpmn:incoming>
      <bpmn:outgoing>F_Next_Orient</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:sendTask id="Send_Orientar" name="Presentar orientación y esperar decisión" messageRef="Message_Orientacion">
      <bpmn:incoming>F_Next_Orient</bpmn:incoming>
      <bpmn:outgoing>F_Orient_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_Orientada" name="Sesión orientada; construcción no iniciada">
      <bpmn:incoming>F_Orient_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_Ctx" sourceRef="Start_Arranque" targetRef="Sub_RecuperarContexto"/>
    <bpmn:sequenceFlow id="F_Ctx_Inspect" sourceRef="Sub_RecuperarContexto" targetRef="Task_Inspeccionar"/>
    <bpmn:sequenceFlow id="F_Inspect_Router" sourceRef="Task_Inspeccionar" targetRef="Task_Rutear"/>
    <bpmn:sequenceFlow id="F_Router_Delim" sourceRef="Task_Rutear" targetRef="Task_Delimitar"/>
    <bpmn:sequenceFlow id="F_Delim_G" sourceRef="Task_Delimitar" targetRef="Gateway_Contexto"/>
    <bpmn:sequenceFlow id="F_G_Si" sourceRef="Gateway_Contexto" targetRef="Send_Aclarar" name="Sí"/>
    <bpmn:sequenceFlow id="F_Aclarar_Resp" sourceRef="Send_Aclarar" targetRef="Catch_Respuesta"/>
    <bpmn:sequenceFlow id="F_Resp_Delim" sourceRef="Catch_Respuesta" targetRef="Task_Delimitar"/>
    <bpmn:sequenceFlow id="F_G_No" sourceRef="Gateway_Contexto" targetRef="Sub_DeterminarSiguiente" name="No"/>
    <bpmn:sequenceFlow id="F_Next_Orient" sourceRef="Sub_DeterminarSiguiente" targetRef="Send_Orientar"/>
    <bpmn:sequenceFlow id="F_Orient_End" sourceRef="Send_Orientar" targetRef="End_Orientada"/>
    <bpmn:textAnnotation id="Annotation_Legend">
      <bpmn:text>Subprocesos EXPANDIDOS: el detalle se ve aquí mismo, sin drill-down.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Legend" sourceRef="Annotation_Legend" targetRef="Sub_RecuperarContexto"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_10_Arranca">
    <bpmndi:BPMNPlane id="Plane_Diagram_10_Arranca" bpmnElement="Collaboration_10_Arranca">
      <bpmndi:BPMNShape id="Shape_Participant_Usuario" bpmnElement="Participant_Usuario" isHorizontal="true">
        <dc:Bounds x="200" y="80" width="3500" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Participant_Proyecto" bpmnElement="Participant_Proyecto" isHorizontal="true">
        <dc:Bounds x="200" y="170" width="3500" height="470"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Agente" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="230" y="170" width="3470" height="330"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Motor" bpmnElement="Lane_Motor" isHorizontal="true">
