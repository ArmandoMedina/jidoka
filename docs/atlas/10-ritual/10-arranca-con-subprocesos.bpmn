        <di:waypoint x="2805" y="417"/>
        <di:waypoint x="2880" y="417"/>
        <di:waypoint x="2880" y="355"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Next_Join_End" bpmnElement="Next_Join_End">
        <di:waypoint x="2900" y="335"/>
        <di:waypoint x="2935" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Send_Orientar" bpmnElement="Send_Orientar">
        <dc:Bounds x="3200" y="308" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Orientada" bpmnElement="End_Orientada">
        <dc:Bounds x="3400" y="320" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Start_Ctx" bpmnElement="F_Start_Ctx">
        <di:waypoint x="280" y="335"/>
        <di:waypoint x="320" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_Ctx_Inspect" bpmnElement="F_Ctx_Inspect">
