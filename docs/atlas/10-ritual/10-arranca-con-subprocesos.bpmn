<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_10_Arranca" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collaboration_10_Arranca">
    <bpmn:participant id="Participant_Usuario" name="Usuario" />
    <bpmn:participant id="Participant_Proyecto" name="/jidoka:arranca — abrir y orientar la sesión (sin construir)" processRef="Process_Arranca" />
    <bpmn:messageFlow id="MF_Start" name="/jidoka:arranca" sourceRef="Participant_Usuario" targetRef="Start_Arranque" messageRef="Message_Arranque" />
    <bpmn:messageFlow id="MF_Orient" name="Orientación" sourceRef="Send_Orientar" targetRef="Participant_Usuario" messageRef="Message_Orientacion" />
    <bpmn:textAnnotation id="Ann_Contrato">
      <bpmn:text>Frontmatter = contrato del comando. allowed-tools es la lista blanca CON dientes: Read habilita las @ (contexto); Bash(git/test/powershell) habilita los ! (git, rutear, asientos, plan). Sin ella, ni @ ni ! corren. description/argument-hint: solo UI, no tocan permisos.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Contrato" sourceRef="Ann_Contrato" targetRef="Start_Arranque" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Arranca" name="/jidoka:arranca — abrir y orientar la sesión" isExecutable="false">
    <bpmn:documentation>Fuente: .claude/commands/jidoka/arranca.md. Estilo Method &amp; Style (Bruce Silver): etiquetas verbo+objeto, el detalle de cada sección vive en su text annotation. §1 se modela en dos pasos que trazan a la misma sección — §1a revisar frescura en git (filtro), §1b cargar el contexto inyectado (@). Luego §2 roster + router (rutear.ps1), §3 el asiento lo ocupa el subagente (casting vivo vía tools/asientos.ps1), §4 desconfía de la compactación (guarda transversal), §5 fija las reglas duras, §6 orienta y espera la señal del cliente. El frontmatter (allowed-tools) se documenta como contrato en Ann_Contrato: Read habilita las @, Bash habilita los !. El STOP final es la señal del cliente antes de construir. Cierra en dos end states que el padre (01-operar-sesion) lee directo — "Orientada: trabajo definido" / "Orientada: sin trabajo definido" — regla Method &amp; Style: los fines del subproceso casan con el gateway del padre ("¿Hay un trabajo definido?").</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_10_Arranca">
      <bpmn:lane id="Lane_Agente" name="Agente orquestador">
        <bpmn:flowNodeRef>T_Git</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Contexto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Router</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Asiento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Reglas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Orientar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Sprint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Planea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Rebanada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Orientar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Arranque</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Humano" name="Humano (cliente)">
        <bpmn:flowNodeRef>U_Senal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Rumbo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ConTrabajo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_SinTrabajo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:serviceTask id="T_Git" name="Revisar frescura en git">
      <bpmn:incoming>F_Start_Git</bpmn:incoming>
      <bpmn:outgoing>F_Git_Contexto</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Contexto" name="Cargar el contexto (@)">
      <bpmn:incoming>F_Git_Contexto</bpmn:incoming>
      <bpmn:outgoing>F_Contexto_Router</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Router" name="Ubicar roster y correr router">
      <bpmn:incoming>F_Contexto_Router</bpmn:incoming>
      <bpmn:outgoing>F_Router_Asiento</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="T_Asiento" name="Delegar el asiento">
      <bpmn:incoming>F_Router_Asiento</bpmn:incoming>
      <bpmn:outgoing>F_Asiento_Reglas</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Reglas" name="Fijar reglas duras">
      <bpmn:incoming>F_Asiento_Reglas</bpmn:incoming>
      <bpmn:outgoing>F_Reglas_Orientar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Orientar" name="Orientar la sesión">
      <bpmn:incoming>F_Reglas_Orientar</bpmn:incoming>
      <bpmn:outgoing>F_Orientar_G</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Sprint" name="¿Amerita un sprint?">
      <bpmn:incoming>F_Orientar_G</bpmn:incoming>
      <bpmn:outgoing>F_G_Si</bpmn:outgoing>
      <bpmn:outgoing>F_G_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Planea" name="Proponer /jidoka:planea">
      <bpmn:incoming>F_G_Si</bpmn:incoming>
      <bpmn:outgoing>F_Planea_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Rebanada" name="Proponer acción acotada">
      <bpmn:incoming>F_G_No</bpmn:incoming>
      <bpmn:outgoing>F_Rebanada_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Join">
      <bpmn:incoming>F_Planea_Join</bpmn:incoming>
      <bpmn:incoming>F_Rebanada_Join</bpmn:incoming>
      <bpmn:outgoing>F_Join_Orient</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Send_Orientar" name="Presentar orientación" messageRef="Message_Orientacion">
      <bpmn:incoming>F_Join_Orient</bpmn:incoming>
      <bpmn:outgoing>F_Orient_Senal</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="F_Start_Git" sourceRef="Start_Arranque" targetRef="T_Git" />
    <bpmn:sequenceFlow id="F_Git_Contexto" sourceRef="T_Git" targetRef="T_Contexto" />
    <bpmn:sequenceFlow id="F_Contexto_Router" sourceRef="T_Contexto" targetRef="T_Router" />
    <bpmn:sequenceFlow id="F_Router_Asiento" sourceRef="T_Router" targetRef="T_Asiento" />
    <bpmn:sequenceFlow id="F_Asiento_Reglas" sourceRef="T_Asiento" targetRef="T_Reglas" />
    <bpmn:sequenceFlow id="F_Reglas_Orientar" sourceRef="T_Reglas" targetRef="T_Orientar" />
    <bpmn:sequenceFlow id="F_Orientar_G" sourceRef="T_Orientar" targetRef="Gw_Sprint" />
    <bpmn:sequenceFlow id="F_G_Si" name="sí" sourceRef="Gw_Sprint" targetRef="T_Planea" />
    <bpmn:sequenceFlow id="F_G_No" name="no" sourceRef="Gw_Sprint" targetRef="T_Rebanada" />
    <bpmn:sequenceFlow id="F_Planea_Join" sourceRef="T_Planea" targetRef="Gw_Join" />
    <bpmn:sequenceFlow id="F_Rebanada_Join" sourceRef="T_Rebanada" targetRef="Gw_Join" />
    <bpmn:sequenceFlow id="F_Join_Orient" sourceRef="Gw_Join" targetRef="Send_Orientar" />
    <bpmn:sequenceFlow id="F_Orient_Senal" sourceRef="Send_Orientar" targetRef="U_Senal" />
    <bpmn:sequenceFlow id="F_Senal_Rumbo" sourceRef="U_Senal" targetRef="Gw_Rumbo" />
    <bpmn:sequenceFlow id="F_Rumbo_Si" name="sí" sourceRef="Gw_Rumbo" targetRef="End_ConTrabajo" />
    <bpmn:sequenceFlow id="F_Rumbo_No" name="no" sourceRef="Gw_Rumbo" targetRef="End_SinTrabajo" />
    <bpmn:startEvent id="Start_Arranque" name="Solicitud /jidoka:arranca recibida">
      <bpmn:outgoing>F_Start_Git</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Start_Arranque" messageRef="Message_Arranque" />
    </bpmn:startEvent>
    <bpmn:userTask id="U_Senal" name="Dar la señal">
      <bpmn:incoming>F_Orient_Senal</bpmn:incoming>
      <bpmn:outgoing>F_Senal_Rumbo</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_Rumbo" name="¿La señal define un trabajo?">
      <bpmn:incoming>F_Senal_Rumbo</bpmn:incoming>
      <bpmn:outgoing>F_Rumbo_Si</bpmn:outgoing>
      <bpmn:outgoing>F_Rumbo_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_ConTrabajo" name="Orientada: trabajo definido">
      <bpmn:incoming>F_Rumbo_Si</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_SinTrabajo" name="Orientada: sin trabajo definido">
      <bpmn:incoming>F_Rumbo_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Ann_Compactacion">
      <bpmn:text>§4 GUARDA — desconfía de la compactación: verifica el HANDOFF y el plan (§1b) contra el artefacto real, no contra el resumen. La compactación puede mentir.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Git">
      <bpmn:text>§1a · git branch --show-current · git status --short · git log --oneline -5. Filtro de frescura: si el HANDOFF contradice a git, git gana. Nada sirve si el repo ya no está donde el doc cree.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Contexto">
      <bpmn:text>§1b · Inyección @ en orden qué → cómo → dónde: PRODUCT_BRIEF (qué), CONTRIBUTING + infra (cómo), HANDOFF + plan del día (dónde). Un @ es un hecho, no un puntero (ADR 0034).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Router">
      <bpmn:text>§2 · rutear.ps1 = preview de gates: lo que toques, esos gates te vigilan al cerrar. El roster (tabla de responsables, no un asiento que se ocupa) sale del casting con nombres en infra.md §El casting, o de los roles neutrales de kanban/roles.md. Un gate DORMIDO no es permiso: es un área que la ley aún no declara.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Asiento">
      <bpmn:text>§3 · El casting vivo se imprime del artefacto: tools/asientos.ps1 lee .claude/agents/ (asiento + tier fijo, ADR 0033) — el gemelo del router, sin copia en prosa que derive. Sin agentes sembrados: [DEGRADADO] → general-purpose, acusando el asiento. Excepción (hilo principal hace el trabajo): 🎭 Asiento &lt;rol&gt; (en sesión) — por qué.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Reglas">
      <bpmn:text>§5 · 1 sesión escritora · el orquestador no pica en el hilo · evidencia-no-palabra · la disciplina escala con el riesgo · nada de memorias de IA.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Orientar">
      <bpmn:text>§6 · Resumir dónde estamos y qué sigue en orden de valor (HANDOFF / ROADMAP) y esperar la señal del cliente.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Rumbo">
      <bpmn:text>En ambos fines rige el STOP: sin construir sin el QUÉ aprobado. El padre (01-operar-sesion) rutea según el fin: "trabajo definido" → ¿QUÉ claro? · "sin trabajo" → /jidoka:que-sigue.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Compactacion" sourceRef="Ann_Compactacion" targetRef="T_Contexto" />
    <bpmn:association id="Assoc_Git" sourceRef="Ann_Git" targetRef="T_Git" />
    <bpmn:association id="Assoc_Contexto" sourceRef="Ann_Contexto" targetRef="T_Contexto" />
    <bpmn:association id="Assoc_Router" sourceRef="Ann_Router" targetRef="T_Router" />
    <bpmn:association id="Assoc_Asiento" sourceRef="Ann_Asiento" targetRef="T_Asiento" />
    <bpmn:association id="Assoc_Reglas" sourceRef="Ann_Reglas" targetRef="T_Reglas" />
    <bpmn:association id="Assoc_Orientar" sourceRef="Ann_Orientar" targetRef="T_Orientar" />
    <bpmn:association id="Assoc_Rumbo" sourceRef="Ann_Rumbo" targetRef="Gw_Rumbo" />
  </bpmn:process>
  <bpmn:message id="Message_Arranque" name="Solicitud /jidoka:arranca" />
  <bpmn:message id="Message_Orientacion" name="Orientación de sesión" />
