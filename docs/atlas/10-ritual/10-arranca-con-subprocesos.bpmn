        <dc:Bounds x="2200" y="215" width="920" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Start" bpmnElement="Next_Start">
        <dc:Bounds x="2225" y="320" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Docs" bpmnElement="Next_Docs">
        <dc:Bounds x="2275" y="308" width="140" height="54"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Eval" bpmnElement="Next_Eval">
        <dc:Bounds x="2435" y="308" width="140" height="54"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Plan" bpmnElement="Next_Plan" isMarkerVisible="true">
        <dc:Bounds x="2595" y="315" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Recomendar" bpmnElement="Next_Recomendar">
        <dc:Bounds x="2665" y="245" width="140" height="54"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Accion" bpmnElement="Next_Accion">
        <dc:Bounds x="2665" y="390" width="140" height="54"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_Join" bpmnElement="Next_Join" isMarkerVisible="true">
        <dc:Bounds x="2860" y="315" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Next_End" bpmnElement="Next_End">
        <dc:Bounds x="2935" y="320" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Next_F1" bpmnElement="Next_F1">
        <di:waypoint x="2255" y="335"/>
        <di:waypoint x="2275" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Next_F2" bpmnElement="Next_F2">
        <di:waypoint x="2415" y="335"/>
        <di:waypoint x="2435" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Next_F3" bpmnElement="Next_F3">
        <di:waypoint x="2575" y="335"/>
        <di:waypoint x="2595" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Next_Si" bpmnElement="Next_Si">
        <di:waypoint x="2615" y="315"/>
        <di:waypoint x="2615" y="272"/>
        <di:waypoint x="2665" y="272"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Next_No" bpmnElement="Next_No">
        <di:waypoint x="2615" y="355"/>
        <di:waypoint x="2615" y="417"/>
        <di:waypoint x="2665" y="417"/>
      </bpmndi:BPMNEdge>
