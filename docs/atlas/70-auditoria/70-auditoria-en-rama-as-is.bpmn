  <bpmn:process id="Process_AuditoriaRama" name="Auditoría integral en rama" isExecutable="false">
    <bpmn:documentation>Fuente: kanban/auditoria.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Rama</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Rama" name="Crear rama de auditoría">
      <bpmn:incoming>F_Start_Task_Rama</bpmn:incoming>
      <bpmn:outgoing>F_Task_Rama_Task_Fanout</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Rama" sourceRef="Start" targetRef="Task_Rama"/>
    <bpmn:serviceTask id="Task_Fanout" name="Despachar auditores por área">
      <bpmn:incoming>F_Task_Rama_Task_Fanout</bpmn:incoming>
      <bpmn:outgoing>F_Task_Fanout_Task_Sintesis</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Rama_Task_Fanout" sourceRef="Task_Rama" targetRef="Task_Fanout"/>
    <bpmn:task id="Task_Sintesis" name="Deduplicar y reconciliar hallazgos">
      <bpmn:incoming>F_Task_Fanout_Task_Sintesis</bpmn:incoming>
      <bpmn:outgoing>F_Task_Sintesis_Task_Paquetes</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Fanout_Task_Sintesis" sourceRef="Task_Fanout" targetRef="Task_Sintesis"/>
    <bpmn:task id="Task_Paquetes" name="Agrupar paquetes de remediación">
      <bpmn:incoming>F_Task_Sintesis_Task_Paquetes</bpmn:incoming>
      <bpmn:outgoing>F_Task_Paquetes_Task_Veredictos</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Sintesis_Task_Paquetes" sourceRef="Task_Sintesis" targetRef="Task_Paquetes"/>
    <bpmn:userTask id="Task_Veredictos" name="Emitir GO/NO-GO por acción">
      <bpmn:incoming>F_Task_Paquetes_Task_Veredictos</bpmn:incoming>
      <bpmn:outgoing>F_Task_Veredictos_Task_Registrar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Paquetes_Task_Veredictos" sourceRef="Task_Paquetes" targetRef="Task_Veredictos"/>
    <bpmn:task id="Task_Registrar" name="Registrar descartes y decisiones humanas">
      <bpmn:incoming>F_Task_Veredictos_Task_Registrar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Registrar_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Veredictos_Task_Registrar" sourceRef="Task_Veredictos" targetRef="Task_Registrar"/>
    <bpmn:endEvent id="End" name="Auditoría con evidencia y veredictos">
      <bpmn:incoming>F_Task_Registrar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Registrar_End" sourceRef="Task_Registrar" targetRef="End"/>
  </bpmn:process>
