<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_72_Homologacion" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_Homologacion" name="Homologar conocimiento de un hijo al método" isExecutable="false">
    <bpmn:documentation>Fuente: kanban/homologacion.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Lección de campo registrada">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Inventario" name="Inventariar pieza, estado y dolor repetido">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_Clasificar" name="Clasificar con el cliente">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Destino" name="¿Destino de la lección?">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F_G_0</bpmn:outgoing>
      <bpmn:outgoing>F_G_1</bpmn:outgoing>
      <bpmn:outgoing>F_G_2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Ascender" name="Neutralizar y diseñar para ascenso">
      <bpmn:incoming>F_G_0</bpmn:incoming>
      <bpmn:outgoing>F_Task_Ascender_J</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Esperar" name="Dejar esperando maduración 2–3">
      <bpmn:incoming>F_G_1</bpmn:incoming>
      <bpmn:outgoing>F_Task_Esperar_J</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Descartar" name="Descartar con razón registrada">
      <bpmn:incoming>F_G_2</bpmn:incoming>
      <bpmn:outgoing>F_Task_Descartar_J</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Join">
      <bpmn:incoming>F_Task_Ascender_J</bpmn:incoming>
      <bpmn:incoming>F_Task_Esperar_J</bpmn:incoming>
      <bpmn:incoming>F_Task_Descartar_J</bpmn:incoming>
      <bpmn:outgoing>F_J_NDA</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_NDA" name="Verificar frontera NDA">
      <bpmn:incoming>F_J_NDA</bpmn:incoming>
      <bpmn:outgoing>F_NDA_ADR</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_ADR" name="Registrar decisión en ADR">
      <bpmn:incoming>F_NDA_ADR</bpmn:incoming>
      <bpmn:outgoing>F_ADR_Ver</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_Verificar" name="Verificar Jidoka y publicar si aplica">
      <bpmn:incoming>F_ADR_Ver</bpmn:incoming>
      <bpmn:outgoing>F_Ver_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Lección ascendida, diferida o descartada">
      <bpmn:incoming>F_Ver_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="Task_Inventario"/>
    <bpmn:sequenceFlow id="F2" sourceRef="Task_Inventario" targetRef="Task_Clasificar"/>
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Clasificar" targetRef="Gateway_Destino"/>
    <bpmn:sequenceFlow id="F_G_0" sourceRef="Gateway_Destino" targetRef="Task_Ascender" name="Asciende"/>
    <bpmn:sequenceFlow id="F_Task_Ascender_J" sourceRef="Task_Ascender" targetRef="Gateway_Join"/>
    <bpmn:sequenceFlow id="F_G_1" sourceRef="Gateway_Destino" targetRef="Task_Esperar" name="Espera"/>
    <bpmn:sequenceFlow id="F_Task_Esperar_J" sourceRef="Task_Esperar" targetRef="Gateway_Join"/>
    <bpmn:sequenceFlow id="F_G_2" sourceRef="Gateway_Destino" targetRef="Task_Descartar" name="Descarta"/>
    <bpmn:sequenceFlow id="F_Task_Descartar_J" sourceRef="Task_Descartar" targetRef="Gateway_Join"/>
    <bpmn:sequenceFlow id="F_J_NDA" sourceRef="Gateway_Join" targetRef="Task_NDA"/>
    <bpmn:sequenceFlow id="F_NDA_ADR" sourceRef="Task_NDA" targetRef="Task_ADR"/>
    <bpmn:sequenceFlow id="F_ADR_Ver" sourceRef="Task_ADR" targetRef="Task_Verificar"/>
    <bpmn:sequenceFlow id="F_Ver_End" sourceRef="Task_Verificar" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_72_Homologacion">
    <bpmndi:BPMNPlane id="Plane_Diagram_72_Homologacion" bpmnElement="Process_Homologacion">
