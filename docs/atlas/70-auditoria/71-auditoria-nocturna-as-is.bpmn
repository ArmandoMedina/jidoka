<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_71_AuditNoct" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_AuditoriaNocturna" name="Auditoría desatendida nocturna" isExecutable="false">
    <bpmn:documentation>Fuente: kanban/auditoria.md y kanban/desatendido.md</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Reconocer</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Reconocer" name="Reconocer también lo sano">
      <bpmn:incoming>F_Start_Task_Reconocer</bpmn:incoming>
      <bpmn:outgoing>F_Task_Reconocer_Task_Agenda</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Start_Task_Reconocer" sourceRef="Start" targetRef="Task_Reconocer"/>
    <bpmn:task id="Task_Agenda" name="Actualizar agenda persistente">
      <bpmn:incoming>F_Task_Reconocer_Task_Agenda</bpmn:incoming>
      <bpmn:outgoing>F_Task_Agenda_Task_Agente</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Reconocer_Task_Agenda" sourceRef="Task_Reconocer" targetRef="Task_Agenda"/>
    <bpmn:serviceTask id="Task_Agente" name="Ejecutar hallazgos reversibles">
      <bpmn:incoming>F_Task_Agenda_Task_Agente</bpmn:incoming>
      <bpmn:outgoing>F_Task_Agente_Task_Humano</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Agenda_Task_Agente" sourceRef="Task_Agenda" targetRef="Task_Agente"/>
    <bpmn:task id="Task_Humano" name="Preparar decisiones para el humano">
      <bpmn:incoming>F_Task_Agente_Task_Humano</bpmn:incoming>
      <bpmn:outgoing>F_Task_Humano_Task_Cierre</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Agente_Task_Humano" sourceRef="Task_Agente" targetRef="Task_Humano"/>
    <bpmn:task id="Task_Cierre" name="Cerrar cada ítem con evidencia">
      <bpmn:incoming>F_Task_Humano_Task_Cierre</bpmn:incoming>
      <bpmn:outgoing>F_Task_Cierre_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Humano_Task_Cierre" sourceRef="Task_Humano" targetRef="Task_Cierre"/>
    <bpmn:endEvent id="End" name="Agenda priorizada y pendientes humanos listos">
      <bpmn:incoming>F_Task_Cierre_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Cierre_End" sourceRef="Task_Cierre" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_71_AuditNoct">
    <bpmndi:BPMNPlane id="Plane_Diagram_71_AuditNoct" bpmnElement="Process_AuditoriaNocturna">
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="Start">
        <dc:Bounds x="80" y="220" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Reconocer" bpmnElement="Task_Reconocer">
        <dc:Bounds x="180" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Start_Task_Reconocer" bpmnElement="F_Start_Task_Reconocer">
        <di:waypoint x="116" y="238"/>
        <di:waypoint x="180" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Agenda" bpmnElement="Task_Agenda">
        <dc:Bounds x="410" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Reconocer_Task_Agenda" bpmnElement="F_Task_Reconocer_Task_Agenda">
        <di:waypoint x="350" y="238"/>
        <di:waypoint x="410" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Agente" bpmnElement="Task_Agente">
        <dc:Bounds x="640" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Agenda_Task_Agente" bpmnElement="F_Task_Agenda_Task_Agente">
        <di:waypoint x="580" y="238"/>
        <di:waypoint x="640" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Humano" bpmnElement="Task_Humano">
        <dc:Bounds x="870" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Agente_Task_Humano" bpmnElement="F_Task_Agente_Task_Humano">
        <di:waypoint x="810" y="238"/>
        <di:waypoint x="870" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Cierre" bpmnElement="Task_Cierre">
        <dc:Bounds x="1100" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Humano_Task_Cierre" bpmnElement="F_Task_Humano_Task_Cierre">
        <di:waypoint x="1040" y="238"/>
        <di:waypoint x="1100" y="238"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_End" bpmnElement="End">
        <dc:Bounds x="1330" y="220" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Cierre_End" bpmnElement="F_Task_Cierre_End">
        <di:waypoint x="1270" y="238"/>
        <di:waypoint x="1330" y="238"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
