<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_80_Publicar" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collab_Publicar">
    <bpmn:participant id="Pool_Publicar" name="publicar — release derivado del SSOT con OK del dueño" processRef="Process_PublicarRelease"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_PublicarRelease" name="publicar el release: derivar del SSOT, suite de tests, guardas y OK del dueño" isExecutable="false">
    <bpmn:documentation>Fuente: tools/publicar.ps1. Secciones: 1-leer version SSOT, 2-derivar notas, 3-guardas, 4-suite de self-tests (probar-* + auditar.ps1 con Test-Path guard), 5-crear release. El OK del humano es la invocacion del script, no un paso separado en la secuencia.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Publicar">
      <bpmn:lane id="Lane_Agente" name="Agente (publicador)">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_LeerVersion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Notas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Guardas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Guardas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_TestPath</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_TestPath</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Suite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Suite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Release</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Abort</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Die</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Humano" name="Humano (dueño)">
        <bpmn:flowNodeRef>Ann_OkHumano</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Release solicitado (humano invoca el script)">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_LeerVersion" name="Leer la versión del SSOT (version.txt)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Notas" name="Derivar título y notas del CHANGELOG">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Guardas" name="Verificar main, árbol limpio y tag ausente">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_Guardas" name="¿Guardas OK?">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f_no</bpmn:outgoing>
      <bpmn:outgoing>f_si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Abort" name="Aborta (no publica)">
      <bpmn:incoming>f_no</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="T_TestPath" name="Test-Path guard: verificar que cada probar-*.ps1 y auditar.ps1 existen en disco">
      <bpmn:documentation>Guarda ADR 0032 / issue #78: si el archivo del test no existe (AV quarantine, falta) Die inmediato. El juez que no midio no aprueba. LASTEXITCODE se resetea a 0 antes de cada test.</bpmn:documentation>
      <bpmn:incoming>f_si</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_TestPath" name="¿Todos los archivos de test en disco?">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f_tp_no</bpmn:outgoing>
      <bpmn:outgoing>f_tp_si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Die" name="Die: test no existe en disco (AV? no se publica a ciegas)">
      <bpmn:incoming>f_tp_no</bpmn:incoming>
      <bpmn:incoming>f_suite_no</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="T_Suite" name="Suite de self-tests: probar-version, probar-gate, probar-hooks, probar-auditor, probar-disparos, probar-instalador, probar-sembrar, probar-agentes, auditar.ps1">
      <bpmn:documentation>Seccion 4 de publicar.ps1. Cada test corre con ErrorActionPreference=Continue; LASTEXITCODE != 0 llama Die. Todos deben estar en disco (verificado por T_TestPath).</bpmn:documentation>
      <bpmn:incoming>f_tp_si</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_Suite" name="¿Suite verde?">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f_suite_no</bpmn:outgoing>
      <bpmn:outgoing>f_suite_si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_Release" name="Crear tag anotado y GitHub release (gh release create)">
      <bpmn:incoming>f_suite_si</bpmn:incoming>
      <bpmn:outgoing>f_rel_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Release publicado">
      <bpmn:incoming>f_rel_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Ann_OkHumano">
      <bpmn:text>El OK del dueño ES la invocacion del script. No hay userTask separado: quien corre publicar.ps1 desde main ya autorizó.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OkHumano" sourceRef="Ann_OkHumano" targetRef="Start"/>
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="T_LeerVersion"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_LeerVersion" targetRef="T_Notas"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_Notas" targetRef="T_Guardas"/>
    <bpmn:sequenceFlow id="f4" sourceRef="T_Guardas" targetRef="Gw_Guardas"/>
    <bpmn:sequenceFlow id="f_no" name="no" sourceRef="Gw_Guardas" targetRef="End_Abort"/>
    <bpmn:sequenceFlow id="f_si" name="sí" sourceRef="Gw_Guardas" targetRef="T_TestPath"/>
    <bpmn:sequenceFlow id="f5" sourceRef="T_TestPath" targetRef="Gw_TestPath"/>
    <bpmn:sequenceFlow id="f_tp_no" name="falta alguno (Die)" sourceRef="Gw_TestPath" targetRef="End_Die"/>
    <bpmn:sequenceFlow id="f_tp_si" name="todos en disco" sourceRef="Gw_TestPath" targetRef="T_Suite"/>
    <bpmn:sequenceFlow id="f6" sourceRef="T_Suite" targetRef="Gw_Suite"/>
    <bpmn:sequenceFlow id="f_suite_no" name="rojo (Die)" sourceRef="Gw_Suite" targetRef="End_Die"/>
    <bpmn:sequenceFlow id="f_suite_si" name="verde" sourceRef="Gw_Suite" targetRef="T_Release"/>
    <bpmn:sequenceFlow id="f_rel_end" sourceRef="T_Release" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_80_Publicar">
    <bpmndi:BPMNPlane id="Plane_80_Publicar" bpmnElement="Collab_Publicar">
      <bpmndi:BPMNShape id="S_Pool" bpmnElement="Pool_Publicar" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1960" height="430"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneA" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1930" height="280"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneH" bpmnElement="Lane_Humano" isHorizontal="true">
        <dc:Bounds x="190" y="360" width="1930" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="210" y="205" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="185" y="238" width="84" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TLeerVersion" bpmnElement="T_LeerVersion">
        <dc:Bounds x="280" y="190" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TNotas" bpmnElement="T_Notas">
        <dc:Bounds x="490" y="190" width="170" height="60"/>
      </bpmndi:BPMNShape>
