        <dc:Bounds x="710" y="190" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwGuardas" bpmnElement="Gw_Guardas" isMarkerVisible="true">
        <dc:Bounds x="930" y="200" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="918" y="163" width="66" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndAbort" bpmnElement="End_Abort">
        <dc:Bounds x="935" y="290" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="910" y="322" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TTestPath" bpmnElement="T_TestPath">
        <dc:Bounds x="1020" y="190" width="190" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwTestPath" bpmnElement="Gw_TestPath" isMarkerVisible="true">
        <dc:Bounds x="1260" y="200" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1242" y="163" width="78" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndDie" bpmnElement="End_Die">
        <dc:Bounds x="1265" y="295" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1230" y="328" width="104" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TSuite" bpmnElement="T_Suite">
        <dc:Bounds x="1350" y="185" width="250" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwSuite" bpmnElement="Gw_Suite" isMarkerVisible="true">
        <dc:Bounds x="1650" y="200" width="40" height="40"/>
