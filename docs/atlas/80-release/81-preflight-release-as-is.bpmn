<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_81_Preflight" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="Jidoka Atlas" exporterVersion="0.3" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:collaboration id="Collab_Preflight">
    <bpmn:participant id="Pool_Preflight" name="preflight (-SoloVerificar) — la suite completa antes de publicar" processRef="Process_PreflightRelease"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_PreflightRelease" name="preflight: correr toda la suite y no publicar si algo está rojo" isExecutable="false">
    <bpmn:documentation>Fuente: tools/publicar.ps1 -SoloVerificar. Proceso de puro motor/CI: corre las suites en secuencia y su decision es si todo quedo verde. Test-Path guard (ADR 0032): Die inmediato si algun probar-*.ps1 no existe en disco (AV/cuarentena). LASTEXITCODE se resetea a 0 antes de cada test.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Preflight">
      <bpmn:lane id="Lane_Motor" name="Motor / CI">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_TestPath</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_TestPath</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Version</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Gate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Hooks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Auditor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Disparos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Instalador</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Agentes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Grafo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Verde</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Verde</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rojo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Die</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="preflight (-SoloVerificar)">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_TestPath" name="Test-Path guard: verificar que todos los probar-*.ps1 y auditar.ps1 existen en disco">
      <bpmn:documentation>ADR 0032 / issue #78. Falla CERRADO si un archivo de test no existe (AV quarantine). El juez que no midio no aprueba.</bpmn:documentation>
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f0b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_TestPath" name="¿Todos en disco?">
      <bpmn:incoming>f0b</bpmn:incoming>
      <bpmn:outgoing>f_die</bpmn:outgoing>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Die" name="Die: test ausente en disco (AV? no se publica)">
      <bpmn:incoming>f_die</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="T_Version" name="Validar el SSOT de versión (probar-version)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Gate" name="probar-gate">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Hooks" name="probar-hooks">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Auditor" name="probar-auditor">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Disparos" name="probar-disparos">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Instalador" name="probar-instalador y probar-sembrar">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Agentes" name="probar-agentes">
      <bpmn:documentation>Agregado en suite v1.18+. Verifica que los agentes del harness responden correctamente.</bpmn:documentation>
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f7b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_Grafo" name="auditar el grafo de producto (auditar.ps1)">
      <bpmn:incoming>f7b</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_Verde" name="¿Todas verdes?">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f_verde</bpmn:outgoing>
      <bpmn:outgoing>f_rojo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Verde" name="Preflight verde (listo para publicar)">
      <bpmn:incoming>f_verde</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Rojo" name="Preflight rojo (no publica)">
      <bpmn:incoming>f_rojo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f0" sourceRef="Start" targetRef="T_TestPath"/>
    <bpmn:sequenceFlow id="f0b" sourceRef="T_TestPath" targetRef="Gw_TestPath"/>
    <bpmn:sequenceFlow id="f_die" name="falta (Die)" sourceRef="Gw_TestPath" targetRef="End_Die"/>
    <bpmn:sequenceFlow id="f1" name="todos OK" sourceRef="Gw_TestPath" targetRef="T_Version"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_Version" targetRef="T_Gate"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_Gate" targetRef="T_Hooks"/>
    <bpmn:sequenceFlow id="f4" sourceRef="T_Hooks" targetRef="T_Auditor"/>
    <bpmn:sequenceFlow id="f5" sourceRef="T_Auditor" targetRef="T_Disparos"/>
    <bpmn:sequenceFlow id="f6" sourceRef="T_Disparos" targetRef="T_Instalador"/>
    <bpmn:sequenceFlow id="f7" sourceRef="T_Instalador" targetRef="T_Agentes"/>
    <bpmn:sequenceFlow id="f7b" sourceRef="T_Agentes" targetRef="T_Grafo"/>
    <bpmn:sequenceFlow id="f8" sourceRef="T_Grafo" targetRef="Gw_Verde"/>
    <bpmn:sequenceFlow id="f_verde" name="sí" sourceRef="Gw_Verde" targetRef="End_Verde"/>
    <bpmn:sequenceFlow id="f_rojo" name="no" sourceRef="Gw_Verde" targetRef="End_Rojo"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_81_Preflight">
    <bpmndi:BPMNPlane id="Plane_81_Preflight" bpmnElement="Collab_Preflight">
      <bpmndi:BPMNShape id="S_Pool" bpmnElement="Pool_Preflight" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2120" height="350"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_LaneM" bpmnElement="Lane_Motor" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="2090" height="350"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="210" y="170" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="188" y="203" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TTestPath" bpmnElement="T_TestPath">
        <dc:Bounds x="280" y="155" width="190" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwTestPath" bpmnElement="Gw_TestPath" isMarkerVisible="true">
        <dc:Bounds x="520" y="165" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="505" y="128" width="72" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndDie" bpmnElement="End_Die">
        <dc:Bounds x="525" y="270" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="498" y="302" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TVersion" bpmnElement="T_Version">
        <dc:Bounds x="610" y="155" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TGate" bpmnElement="T_Gate">
        <dc:Bounds x="800" y="155" width="130" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_THooks" bpmnElement="T_Hooks">
        <dc:Bounds x="970" y="155" width="130" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TAuditor" bpmnElement="T_Auditor">
        <dc:Bounds x="1140" y="155" width="130" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TDisparos" bpmnElement="T_Disparos">
        <dc:Bounds x="1310" y="155" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TInstalador" bpmnElement="T_Instalador">
        <dc:Bounds x="1490" y="155" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TAgentes" bpmnElement="T_Agentes">
        <dc:Bounds x="1700" y="155" width="130" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_TGrafo" bpmnElement="T_Grafo">
        <dc:Bounds x="1870" y="155" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GwVerde" bpmnElement="Gw_Verde" isMarkerVisible="true">
        <dc:Bounds x="2070" y="165" width="40" height="40"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2058" y="128" width="66" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndVerde" bpmnElement="End_Verde">
        <dc:Bounds x="2175" y="170" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2150" y="203" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndRojo" bpmnElement="End_Rojo">
        <dc:Bounds x="2075" y="275" width="30" height="30"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2050" y="307" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_f0" bpmnElement="f0">
        <di:waypoint x="240" y="185"/>
        <di:waypoint x="280" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f0b" bpmnElement="f0b">
        <di:waypoint x="470" y="185"/>
        <di:waypoint x="520" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_die" bpmnElement="f_die">
        <di:waypoint x="540" y="205"/>
        <di:waypoint x="540" y="270"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f1" bpmnElement="f1">
        <di:waypoint x="560" y="185"/>
        <di:waypoint x="610" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f2" bpmnElement="f2">
        <di:waypoint x="760" y="185"/>
        <di:waypoint x="800" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f3" bpmnElement="f3">
        <di:waypoint x="930" y="185"/>
        <di:waypoint x="970" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f4" bpmnElement="f4">
        <di:waypoint x="1100" y="185"/>
        <di:waypoint x="1140" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f5" bpmnElement="f5">
        <di:waypoint x="1270" y="185"/>
        <di:waypoint x="1310" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f6" bpmnElement="f6">
        <di:waypoint x="1450" y="185"/>
        <di:waypoint x="1490" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f7" bpmnElement="f7">
        <di:waypoint x="1660" y="185"/>
        <di:waypoint x="1700" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f7b" bpmnElement="f7b">
        <di:waypoint x="1830" y="185"/>
        <di:waypoint x="1870" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f8" bpmnElement="f8">
        <di:waypoint x="2030" y="185"/>
        <di:waypoint x="2070" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_verde" bpmnElement="f_verde">
        <di:waypoint x="2110" y="185"/>
        <di:waypoint x="2175" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_f_rojo" bpmnElement="f_rojo">
        <di:waypoint x="2090" y="205"/>
        <di:waypoint x="2090" y="275"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
