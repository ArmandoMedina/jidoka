  <bpmn:process id="Process_PreflightRelease" name="Ejecutar preflight de release" isExecutable="false">
    <bpmn:documentation>Fuente: tools/publicar.ps1 -SoloVerificar</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Version</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Version" name="Validar SSOT de versión">
      <bpmn:incoming>F_Start_Task_Version</bpmn:incoming>
      <bpmn:outgoing>F_Task_Version_Task_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Start_Task_Version" sourceRef="Start" targetRef="Task_Version"/>
    <bpmn:serviceTask id="Task_Gate" name="Probar gate">
      <bpmn:incoming>F_Task_Version_Task_Gate</bpmn:incoming>
      <bpmn:outgoing>F_Task_Gate_Task_Hooks</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Version_Task_Gate" sourceRef="Task_Version" targetRef="Task_Gate"/>
    <bpmn:serviceTask id="Task_Hooks" name="Probar hooks">
      <bpmn:incoming>F_Task_Gate_Task_Hooks</bpmn:incoming>
      <bpmn:outgoing>F_Task_Hooks_Task_Auditor</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Gate_Task_Hooks" sourceRef="Task_Gate" targetRef="Task_Hooks"/>
    <bpmn:serviceTask id="Task_Auditor" name="Probar auditor">
      <bpmn:incoming>F_Task_Hooks_Task_Auditor</bpmn:incoming>
      <bpmn:outgoing>F_Task_Auditor_Task_Disparos</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Hooks_Task_Auditor" sourceRef="Task_Hooks" targetRef="Task_Auditor"/>
    <bpmn:serviceTask id="Task_Disparos" name="Probar disparos">
      <bpmn:incoming>F_Task_Auditor_Task_Disparos</bpmn:incoming>
      <bpmn:outgoing>F_Task_Disparos_Task_Instalador</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Auditor_Task_Disparos" sourceRef="Task_Auditor" targetRef="Task_Disparos"/>
    <bpmn:serviceTask id="Task_Instalador" name="Probar instalador y siembra">
      <bpmn:incoming>F_Task_Disparos_Task_Instalador</bpmn:incoming>
      <bpmn:outgoing>F_Task_Instalador_Task_Grafo</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Disparos_Task_Instalador" sourceRef="Task_Disparos" targetRef="Task_Instalador"/>
    <bpmn:serviceTask id="Task_Grafo" name="Auditar grafo">
      <bpmn:incoming>F_Task_Instalador_Task_Grafo</bpmn:incoming>
      <bpmn:outgoing>F_Task_Grafo_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Instalador_Task_Grafo" sourceRef="Task_Instalador" targetRef="Task_Grafo"/>
    <bpmn:endEvent id="End" name="Preflight verde">
      <bpmn:incoming>F_Task_Grafo_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Grafo_End" sourceRef="Task_Grafo" targetRef="End"/>
  </bpmn:process>
