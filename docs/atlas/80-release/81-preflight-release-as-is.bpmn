      <bpmndi:BPMNEdge id="Edge_F_Task_Auditor_Task_Disparos" bpmnElement="F_Task_Auditor_Task_Disparos">
        <di:waypoint x="1040" y="238"/>
        <di:waypoint x="1100" y="238"/>
