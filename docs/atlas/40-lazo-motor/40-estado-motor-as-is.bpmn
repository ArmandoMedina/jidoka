      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Task_Detalle" bpmnElement="Task_Detalle">
        <dc:Bounds x="870" y="198" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F_Task_Comparar_Task_Detalle" bpmnElement="F_Task_Comparar_Task_Detalle">
