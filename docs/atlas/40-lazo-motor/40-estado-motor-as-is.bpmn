<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_40_Estado" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_EstadoMotor" name="Consultar estado del motor" isExecutable="false">
    <bpmn:documentation>Fuente: tools/estado-motor.ps1</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Gates</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Gates" name="Mostrar gates vivos y dormidos">
      <bpmn:incoming>F_Start_Task_Gates</bpmn:incoming>
      <bpmn:outgoing>F_Task_Gates_Task_Sello</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Start_Task_Gates" sourceRef="Start" targetRef="Task_Gates"/>
    <bpmn:serviceTask id="Task_Sello" name="Leer sello del hijo">
      <bpmn:incoming>F_Task_Gates_Task_Sello</bpmn:incoming>
      <bpmn:outgoing>F_Task_Sello_Task_Comparar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Gates_Task_Sello" sourceRef="Task_Gates" targetRef="Task_Sello"/>
    <bpmn:serviceTask id="Task_Comparar" name="Comparar versión con Jidoka">
      <bpmn:incoming>F_Task_Sello_Task_Comparar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Comparar_Task_Detalle</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Sello_Task_Comparar" sourceRef="Task_Sello" targetRef="Task_Comparar"/>
    <bpmn:serviceTask id="Task_Detalle" name="Comparar piezas por hash si se solicita">
      <bpmn:incoming>F_Task_Comparar_Task_Detalle</bpmn:incoming>
      <bpmn:outgoing>F_Task_Detalle_Task_Recomendar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Comparar_Task_Detalle" sourceRef="Task_Comparar" targetRef="Task_Detalle"/>
    <bpmn:task id="Task_Recomendar" name="Recomendar ruta de actualización">
      <bpmn:incoming>F_Task_Detalle_Task_Recomendar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Recomendar_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Detalle_Task_Recomendar" sourceRef="Task_Detalle" targetRef="Task_Recomendar"/>
    <bpmn:endEvent id="End" name="Estado y divergencia informados">
      <bpmn:incoming>F_Task_Recomendar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Recomendar_End" sourceRef="Task_Recomendar" targetRef="End"/>
  </bpmn:process>
