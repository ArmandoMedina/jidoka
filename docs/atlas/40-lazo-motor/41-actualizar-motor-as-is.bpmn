<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_41_Actualizar" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2">
  <bpmn:process id="Process_ActualizarMotor" name="Actualizar motor con conciencia de tres vías" isExecutable="false">
    <bpmn:documentation>Fuente: tools/instalar.ps1 -Actualizar</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Actualización solicitada">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Leer" name="Leer manifiesto, sello y exclusiones">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Pieza" name="Tomar siguiente pieza de mecánica">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
      <bpmn:incoming>F_Mas_Si</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Estado" name="¿Estado de la pieza?">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F_G_0</bpmn:outgoing>
      <bpmn:outgoing>F_G_1</bpmn:outgoing>
      <bpmn:outgoing>F_G_2</bpmn:outgoing>
      <bpmn:outgoing>F_G_3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Agregar" name="Agregar pieza ausente">
      <bpmn:incoming>F_G_0</bpmn:incoming>
      <bpmn:outgoing>F_Task_Agregar_Mas</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AlDia" name="Conservar pieza al día">
      <bpmn:incoming>F_G_1</bpmn:incoming>
      <bpmn:outgoing>F_Task_AlDia_Mas</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Actualizar" name="Actualizar pieza no modificada por el hijo">
      <bpmn:incoming>F_G_2</bpmn:incoming>
      <bpmn:outgoing>F_Task_Actualizar_Mas</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Diverge" name="Preservar personalización y dejar .jidoka-nuevo">
      <bpmn:incoming>F_G_3</bpmn:incoming>
      <bpmn:outgoing>F_Task_Diverge_Mas</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Mas" name="¿Quedan piezas?">
      <bpmn:incoming>F_Task_Agregar_Mas</bpmn:incoming>
      <bpmn:incoming>F_Task_AlDia_Mas</bpmn:incoming>
      <bpmn:incoming>F_Task_Actualizar_Mas</bpmn:incoming>
      <bpmn:incoming>F_Task_Diverge_Mas</bpmn:incoming>
      <bpmn:outgoing>F_Mas_Si</bpmn:outgoing>
      <bpmn:outgoing>F_Mas_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Sello" name="Actualizar sello y resumir divergencias">
      <bpmn:incoming>F_Mas_No</bpmn:incoming>
      <bpmn:outgoing>F_Sello_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Motor actualizado; instancia intacta">
      <bpmn:incoming>F_Sello_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="Task_Leer"/>
    <bpmn:sequenceFlow id="F2" sourceRef="Task_Leer" targetRef="Task_Pieza"/>
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Pieza" targetRef="Gateway_Estado"/>
    <bpmn:sequenceFlow id="F_G_0" sourceRef="Gateway_Estado" targetRef="Task_Agregar" name="Ausente"/>
    <bpmn:sequenceFlow id="F_Task_Agregar_Mas" sourceRef="Task_Agregar" targetRef="Gateway_Mas"/>
    <bpmn:sequenceFlow id="F_G_1" sourceRef="Gateway_Estado" targetRef="Task_AlDia" name="Igual a Jidoka"/>
    <bpmn:sequenceFlow id="F_Task_AlDia_Mas" sourceRef="Task_AlDia" targetRef="Gateway_Mas"/>
    <bpmn:sequenceFlow id="F_G_2" sourceRef="Gateway_Estado" targetRef="Task_Actualizar" name="Igual a semilla"/>
    <bpmn:sequenceFlow id="F_Task_Actualizar_Mas" sourceRef="Task_Actualizar" targetRef="Gateway_Mas"/>
    <bpmn:sequenceFlow id="F_G_3" sourceRef="Gateway_Estado" targetRef="Task_Diverge" name="Personalizada"/>
    <bpmn:sequenceFlow id="F_Task_Diverge_Mas" sourceRef="Task_Diverge" targetRef="Gateway_Mas"/>
    <bpmn:sequenceFlow id="F_Mas_Si" sourceRef="Gateway_Mas" targetRef="Task_Pieza" name="Sí"/>
    <bpmn:sequenceFlow id="F_Mas_No" sourceRef="Gateway_Mas" targetRef="Task_Sello" name="No"/>
    <bpmn:sequenceFlow id="F_Sello_End" sourceRef="Task_Sello" targetRef="End"/>
  </bpmn:process>
