  <bpmn:process id="Process_SellarMotor" name="Sellar un motor convergido a mano" isExecutable="false">
    <bpmn:documentation>Fuente: tools/instalar.ps1 -Sellar</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Inventario</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Inventario" name="Inventariar piezas de mecánica">
      <bpmn:incoming>F_Start_Task_Inventario</bpmn:incoming>
      <bpmn:outgoing>F_Task_Inventario_Task_Comparar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Start_Task_Inventario" sourceRef="Start" targetRef="Task_Inventario"/>
    <bpmn:serviceTask id="Task_Comparar" name="Comparar hijo contra Jidoka">
