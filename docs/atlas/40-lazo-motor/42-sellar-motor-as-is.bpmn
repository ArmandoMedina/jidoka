    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="F_Task_Comparar_Task_Clasificar" sourceRef="Task_Comparar" targetRef="Task_Clasificar"/>
    <bpmn:serviceTask id="Task_Escribir" name="Escribir sello preservando exclusiones">
      <bpmn:incoming>F_Task_Clasificar_Task_Escribir</bpmn:incoming>
      <bpmn:outgoing>F_Task_Escribir_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Clasificar_Task_Escribir" sourceRef="Task_Clasificar" targetRef="Task_Escribir"/>
    <bpmn:endEvent id="End" name="Motor sellado sin pisar personalizaciones">
      <bpmn:incoming>F_Task_Escribir_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Escribir_End" sourceRef="Task_Escribir" targetRef="End"/>
  </bpmn:process>
