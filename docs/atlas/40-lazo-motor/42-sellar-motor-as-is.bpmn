      <bpmn:outgoing>F_Task_Comparar_Task_Clasificar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Inventario_Task_Comparar" sourceRef="Task_Inventario" targetRef="Task_Comparar"/>
    <bpmn:businessRuleTask id="Task_Clasificar" name="Clasificar prístinas, personalizadas y ausentes">
