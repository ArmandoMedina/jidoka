<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_44_Leccion" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_ReportarLeccion" name="Reportar una lección a Jidoka" isExecutable="false">
    <bpmn:documentation>Fuente: tools/reportar-leccion.ps1</bpmn:documentation>
    <bpmn:startEvent id="Start" name="Inicio">
      <bpmn:outgoing>F_Start_Task_Anonimizar</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Anonimizar" name="Anonimizar contexto sensible">
      <bpmn:incoming>F_Start_Task_Anonimizar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Anonimizar_Task_Redactar</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Start_Task_Anonimizar" sourceRef="Start" targetRef="Task_Anonimizar"/>
    <bpmn:task id="Task_Redactar" name="Redactar la lección y dónde se pagó">
      <bpmn:incoming>F_Task_Anonimizar_Task_Redactar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Redactar_Task_Abrir</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="F_Task_Anonimizar_Task_Redactar" sourceRef="Task_Anonimizar" targetRef="Task_Redactar"/>
    <bpmn:serviceTask id="Task_Abrir" name="Abrir issue prellenado en Jidoka">
      <bpmn:incoming>F_Task_Redactar_Task_Abrir</bpmn:incoming>
      <bpmn:outgoing>F_Task_Abrir_Task_Esperar</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="F_Task_Redactar_Task_Abrir" sourceRef="Task_Redactar" targetRef="Task_Abrir"/>
    <bpmn:userTask id="Task_Esperar" name="Esperar acuse: construir o diferir por regla 2–3">
      <bpmn:incoming>F_Task_Abrir_Task_Esperar</bpmn:incoming>
      <bpmn:outgoing>F_Task_Esperar_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="F_Task_Abrir_Task_Esperar" sourceRef="Task_Abrir" targetRef="Task_Esperar"/>
    <bpmn:endEvent id="End" name="Lección registrada en el upstream">
      <bpmn:incoming>F_Task_Esperar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Task_Esperar_End" sourceRef="Task_Esperar" targetRef="End"/>
  </bpmn:process>
