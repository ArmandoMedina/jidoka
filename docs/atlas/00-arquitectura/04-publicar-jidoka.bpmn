<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_04_Publicar" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2">
  <bpmn:process id="Process_PublicarJidoka" name="Publicar una versión de Jidoka" isExecutable="false">
    <bpmn:documentation>El release solo continúa si el preflight queda verde.</bpmn:documentation>
    <bpmn:startEvent id="Start_Publicar" name="Versión preparada para publicación">
      <bpmn:outgoing>F_Start_Pre</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:callActivity id="Call_Preflight" name="[81] Ejecutar preflight" calledElement="Process_PreflightRelease">
      <bpmn:documentation>Proceso externo: Process_PreflightRelease | Archivo: 80-release/81-preflight-release-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Start_Pre</bpmn:incoming>
      <bpmn:outgoing>F_Pre_G</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Preflight">
      <bpmn:text>Archivo: 80-release/81-preflight-release-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Preflight" sourceRef="Annotation_Call_Preflight" targetRef="Call_Preflight"/>
    <bpmn:exclusiveGateway id="Gateway_Verde" name="¿Suite verde?">
      <bpmn:incoming>F_Pre_G</bpmn:incoming>
      <bpmn:outgoing>F_G_No</bpmn:outgoing>
      <bpmn:outgoing>F_G_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Detenido" name="Publicación detenida">
      <bpmn:incoming>F_G_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="Call_Publicar" name="[80] Publicar release" calledElement="Process_PublicarRelease">
      <bpmn:documentation>Proceso externo: Process_PublicarRelease | Archivo: 80-release/80-publicar-release-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_G_Si</bpmn:incoming>
      <bpmn:outgoing>F_Pub_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Publicar">
      <bpmn:text>Archivo: 80-release/80-publicar-release-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Publicar" sourceRef="Annotation_Call_Publicar" targetRef="Call_Publicar"/>
    <bpmn:endEvent id="End_Publicado" name="Release publicado">
      <bpmn:incoming>F_Pub_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_Pre" sourceRef="Start_Publicar" targetRef="Call_Preflight"/>
    <bpmn:sequenceFlow id="F_Pre_G" sourceRef="Call_Preflight" targetRef="Gateway_Verde"/>
    <bpmn:sequenceFlow id="F_G_No" sourceRef="Gateway_Verde" targetRef="End_Detenido" name="No"/>
    <bpmn:sequenceFlow id="F_G_Si" sourceRef="Gateway_Verde" targetRef="Call_Publicar" name="Sí"/>
    <bpmn:sequenceFlow id="F_Pub_End" sourceRef="Call_Publicar" targetRef="End_Publicado"/>
  </bpmn:process>
