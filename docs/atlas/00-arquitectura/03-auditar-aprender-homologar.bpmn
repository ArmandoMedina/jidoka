    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Auditar" sourceRef="Annotation_Call_Auditar" targetRef="Call_Auditar"/>
    <bpmn:endEvent id="End_A" name="Auditoría sintetizada">
