    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_G_1" sourceRef="Gateway_Nec" targetRef="Call_Noct" name="Auditar desatendido"/>
    <bpmn:sequenceFlow id="F_Call_Noct_E" sourceRef="Call_Noct" targetRef="End_N"/>
    <bpmn:callActivity id="Call_Hom" name="[72] Homologar conocimiento al método" calledElement="Process_Homologacion">
