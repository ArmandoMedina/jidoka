    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_G_2" sourceRef="Gateway_Nec" targetRef="Call_Hom" name="Homologar"/>
    <bpmn:sequenceFlow id="F_Call_Hom_E" sourceRef="Call_Hom" targetRef="End_H"/>
    <bpmn:sequenceFlow id="F_Start_G" sourceRef="Start_Nec" targetRef="Gateway_Nec"/>
  </bpmn:process>
