    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_G_0" sourceRef="Gateway_Nec" targetRef="Call_Auditar" name="Auditar"/>
    <bpmn:sequenceFlow id="F_Call_Auditar_E" sourceRef="Call_Auditar" targetRef="End_A"/>
    <bpmn:callActivity id="Call_Noct" name="[71] Auditar sin humano presente" calledElement="Process_AuditoriaNocturna">
      <bpmn:documentation>Proceso externo: Process_AuditoriaNocturna | Archivo: 70-auditoria/71-auditoria-nocturna-as-is.bpmn</bpmn:documentation>
