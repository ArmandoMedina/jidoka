      <bpmn:outgoing>F_G_1</bpmn:outgoing>
      <bpmn:outgoing>F_G_2</bpmn:outgoing>
      <bpmn:incoming>F_Start_G</bpmn:incoming>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Auditar" name="[70] Auditar en rama" calledElement="Process_AuditoriaRama">
      <bpmn:documentation>Proceso externo: Process_AuditoriaRama | Archivo: 70-auditoria/70-auditoria-en-rama-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_G_0</bpmn:incoming>
      <bpmn:outgoing>F_Call_Auditar_E</bpmn:outgoing>
