<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_00_Arquitectura" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:process id="Process_SeleccionarFamilia" name="Arquitectura de procesos de Jidoka" isExecutable="false">
    <bpmn:documentation>Mapa de navegación. No implica que las cuatro familias se ejecuten en secuencia.</bpmn:documentation>
    <bpmn:startEvent id="Start_Necesidad" name="Necesidad de actuar con Jidoka">
      <bpmn:outgoing>Flow_Start_Identificar</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Identificar" name="Identificar la necesidad operativa">
      <bpmn:incoming>Flow_Start_Identificar</bpmn:incoming>
      <bpmn:outgoing>Flow_Identificar_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Familia" name="¿Qué necesitas hacer?">
      <bpmn:incoming>Flow_Identificar_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_1</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_2</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_OperarSesion" name="[01] Operar una sesión y entregar un incremento" calledElement="Process_OperarSesion">
      <bpmn:documentation>Proceso externo: Process_OperarSesion | Archivo: 00-arquitectura/01-operar-sesion-entregar-incremento.bpmn</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Call_OperarSesion_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_Operar" name="Familia de sesión seleccionada">
      <bpmn:incoming>Flow_Call_OperarSesion_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Gateway_1" name="Sesión / entrega" sourceRef="Gateway_Familia" targetRef="Call_OperarSesion" />
    <bpmn:sequenceFlow id="Flow_Call_OperarSesion_End" sourceRef="Call_OperarSesion" targetRef="End_Operar" />
    <bpmn:callActivity id="Call_InstalarMantener" name="[02] Instalar o mantener el método" calledElement="Process_InstalarMantener">
      <bpmn:documentation>Proceso externo: Process_InstalarMantener | Archivo: 00-arquitectura/02-instalar-mantener-metodo.bpmn</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Call_InstalarMantener_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_Instalar" name="Familia de instalación/mantenimiento seleccionada">
      <bpmn:incoming>Flow_Call_InstalarMantener_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Gateway_2" name="Adopción / motor" sourceRef="Gateway_Familia" targetRef="Call_InstalarMantener" />
    <bpmn:sequenceFlow id="Flow_Call_InstalarMantener_End" sourceRef="Call_InstalarMantener" targetRef="End_Instalar" />
    <bpmn:callActivity id="Call_AuditarHomologar" name="[03] Auditar, aprender u homologar" calledElement="Process_AuditarHomologar">
      <bpmn:documentation>Proceso externo: Process_AuditarHomologar | Archivo: 00-arquitectura/03-auditar-aprender-homologar.bpmn</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Call_AuditarHomologar_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_Auditar" name="Familia de auditoría/aprendizaje seleccionada">
      <bpmn:incoming>Flow_Call_AuditarHomologar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Gateway_3" name="Auditoría / aprendizaje" sourceRef="Gateway_Familia" targetRef="Call_AuditarHomologar" />
    <bpmn:sequenceFlow id="Flow_Call_AuditarHomologar_End" sourceRef="Call_AuditarHomologar" targetRef="End_Auditar" />
    <bpmn:callActivity id="Call_Publicar" name="[04] Publicar una versión de Jidoka" calledElement="Process_PublicarJidoka">
      <bpmn:documentation>Proceso externo: Process_PublicarJidoka | Archivo: 00-arquitectura/04-publicar-jidoka.bpmn</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Call_Publicar_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_Publicar" name="Familia de publicación seleccionada">
      <bpmn:incoming>Flow_Call_Publicar_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Gateway_4" name="Release" sourceRef="Gateway_Familia" targetRef="Call_Publicar" />
    <bpmn:sequenceFlow id="Flow_Call_Publicar_End" sourceRef="Call_Publicar" targetRef="End_Publicar" />
    <bpmn:sequenceFlow id="Flow_Start_Identificar" sourceRef="Start_Necesidad" targetRef="Task_Identificar" />
    <bpmn:sequenceFlow id="Flow_Identificar_Gateway" sourceRef="Task_Identificar" targetRef="Gateway_Familia" />
    <bpmn:textAnnotation id="Annotation_Call_OperarSesion">
      <bpmn:text>Archivo: 00-arquitectura/01-operar-sesion-entregar-incremento.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_OperarSesion" sourceRef="Annotation_Call_OperarSesion" targetRef="Call_OperarSesion" />
    <bpmn:textAnnotation id="Annotation_Call_InstalarMantener">
      <bpmn:text>Archivo: 00-arquitectura/02-instalar-mantener-metodo.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_InstalarMantener" sourceRef="Annotation_Call_InstalarMantener" targetRef="Call_InstalarMantener" />
    <bpmn:textAnnotation id="Annotation_Call_AuditarHomologar">
      <bpmn:text>Archivo: 00-arquitectura/03-auditar-aprender-homologar.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_AuditarHomologar" sourceRef="Annotation_Call_AuditarHomologar" targetRef="Call_AuditarHomologar" />
    <bpmn:textAnnotation id="Annotation_Call_Publicar">
      <bpmn:text>Archivo: 00-arquitectura/04-publicar-jidoka.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Publicar" sourceRef="Annotation_Call_Publicar" targetRef="Call_Publicar" />
    <bpmn:textAnnotation id="Annotation_Leyenda">
      <bpmn:text>LEYENDA
Borde grueso = Call Activity: abre otro archivo.
Símbolo + = subproceso embebido: detalle dentro del mismo archivo.
Tarea normal = paso atómico en este nivel.</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
