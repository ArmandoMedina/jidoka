      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Association_Annotation_Call_Gemba" bpmnElement="Association_Annotation_Call_Gemba">
        <di:waypoint x="1930.0" y="326"/>
        <di:waypoint x="1930.0" y="316"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Gateway_Aceptado" bpmnElement="Gateway_Aceptado" isMarkerVisible="true">
        <dc:Bounds x="2060" y="243" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_Cierra" bpmnElement="Call_Cierra">
        <dc:Bounds x="2200" y="228" width="190" height="82"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Annotation_Call_Cierra" bpmnElement="Annotation_Call_Cierra">
        <dc:Bounds x="2200" y="326" width="220" height="40"/>
