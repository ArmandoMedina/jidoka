<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_01_OperarSesion" targetNamespace="https://github.com/ArmandoMedina/jidoka/process-atlas" exporter="OpenAI BPMN Atlas Generator" exporterVersion="0.2" xmlns:modeler="http://camunda.org/schema/modeler/1.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.18.0">
  <bpmn:process id="Process_OperarSesion" name="Operar una sesión y entregar un incremento" isExecutable="false">
    <bpmn:documentation>Nivel 1. Las actividades con borde grueso llaman procesos definidos en archivos separados.</bpmn:documentation>
    <bpmn:startEvent id="Start_Sesion" name="Necesidad de trabajar en el proyecto">
      <bpmn:outgoing>F_Start_Arranca</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:callActivity id="Call_Arranca" name="[10] Arrancar sesión" calledElement="Process_Arranca">
      <bpmn:documentation>Proceso externo: Process_Arranca | Archivo: 10-ritual/10-arranca-con-subprocesos.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Start_Arranca</bpmn:incoming>
      <bpmn:outgoing>F_Arranca_Obj</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Arranca">
      <bpmn:text>Archivo: 10-ritual/10-arranca-con-subprocesos.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Arranca" sourceRef="Annotation_Call_Arranca" targetRef="Call_Arranca"/>
    <bpmn:exclusiveGateway id="Gateway_Objetivo" name="¿Hay un trabajo definido?">
      <bpmn:incoming>F_Arranca_Obj</bpmn:incoming>
      <bpmn:outgoing>F_Obj_No</bpmn:outgoing>
      <bpmn:outgoing>F_Obj_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_QueSigue" name="[17] Decidir qué sigue" calledElement="Process_QueSigue">
      <bpmn:documentation>Proceso externo: Process_QueSigue | Archivo: 10-ritual/17-que-sigue-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Obj_No</bpmn:incoming>
      <bpmn:outgoing>F_QueSigue_Cont</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_QueSigue">
      <bpmn:text>Archivo: 10-ritual/17-que-sigue-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_QueSigue" sourceRef="Annotation_Call_QueSigue" targetRef="Call_QueSigue"/>
    <bpmn:exclusiveGateway id="Gateway_Continuar" name="¿El usuario decide continuar?">
      <bpmn:incoming>F_QueSigue_Cont</bpmn:incoming>
      <bpmn:outgoing>F_Cont_No</bpmn:outgoing>
      <bpmn:outgoing>F_Cont_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_SoloOrientada" name="Sesión orientada sin construcción">
      <bpmn:incoming>F_Cont_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_QueClaro" name="¿El QUÉ está suficientemente claro?">
      <bpmn:incoming>F_Cont_Si</bpmn:incoming>
      <bpmn:incoming>F_Obj_Si</bpmn:incoming>
      <bpmn:outgoing>F_Claro_No</bpmn:outgoing>
      <bpmn:outgoing>F_Claro_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Descubre" name="[11] Descubrir el QUÉ" calledElement="Process_Descubre">
      <bpmn:documentation>Proceso externo: Process_Descubre | Archivo: 10-ritual/11-descubre-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Claro_No</bpmn:incoming>
      <bpmn:outgoing>F_Desc_Aprob</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Descubre">
      <bpmn:text>Archivo: 10-ritual/11-descubre-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Descubre" sourceRef="Annotation_Call_Descubre" targetRef="Call_Descubre"/>
    <bpmn:exclusiveGateway id="Gateway_QueAprobado" name="¿QUÉ aprobado?">
      <bpmn:incoming>F_Desc_Aprob</bpmn:incoming>
      <bpmn:outgoing>F_Aprob_No</bpmn:outgoing>
      <bpmn:outgoing>F_Aprob_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_DefinicionPendiente" name="Definición pendiente">
      <bpmn:incoming>F_Aprob_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_Plan" name="¿Requiere plan de sprint?">
      <bpmn:incoming>F_Aprob_Si</bpmn:incoming>
      <bpmn:incoming>F_Claro_Si</bpmn:incoming>
      <bpmn:outgoing>F_Plan_Si</bpmn:outgoing>
      <bpmn:outgoing>F_Plan_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Planea" name="[12] Planear sprint" calledElement="Process_Planea">
      <bpmn:documentation>Proceso externo: Process_Planea | Archivo: 10-ritual/12-planea-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Plan_Si</bpmn:incoming>
      <bpmn:outgoing>F_Planea_Hum</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Planea">
      <bpmn:text>Archivo: 10-ritual/12-planea-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Planea" sourceRef="Annotation_Call_Planea" targetRef="Call_Planea"/>
    <bpmn:exclusiveGateway id="Gateway_Humano" name="¿Humano presente?">
      <bpmn:incoming>F_Planea_Hum</bpmn:incoming>
      <bpmn:incoming>F_Plan_No</bpmn:incoming>
      <bpmn:outgoing>F_Hum_Si</bpmn:outgoing>
      <bpmn:outgoing>F_Hum_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Construye" name="[13] Construir rebanada" calledElement="Process_Construye">
      <bpmn:documentation>Proceso externo: Process_Construye | Archivo: 10-ritual/13-construye-rebanada-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Hum_Si</bpmn:incoming>
      <bpmn:outgoing>F_Const_Join</bpmn:outgoing>
      <bpmn:incoming>F_Acept_No</bpmn:incoming>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Construye">
      <bpmn:text>Archivo: 10-ritual/13-construye-rebanada-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Construye" sourceRef="Annotation_Call_Construye" targetRef="Call_Construye"/>
    <bpmn:callActivity id="Call_Desatendido" name="[18] Ejecutar pase desatendido" calledElement="Process_Desatendido">
      <bpmn:documentation>Proceso externo: Process_Desatendido | Archivo: 10-ritual/18-desatendido-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Hum_No</bpmn:incoming>
      <bpmn:outgoing>F_Des_Join</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Desatendido">
      <bpmn:text>Archivo: 10-ritual/18-desatendido-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Desatendido" sourceRef="Annotation_Call_Desatendido" targetRef="Call_Desatendido"/>
    <bpmn:exclusiveGateway id="Gateway_UnirConstruccion">
      <bpmn:incoming>F_Const_Join</bpmn:incoming>
      <bpmn:incoming>F_Des_Join</bpmn:incoming>
      <bpmn:outgoing>F_Join_Review</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Revisar" name="[14] Revisar cambio" calledElement="Process_Revisar">
      <bpmn:documentation>Proceso externo: Process_Revisar | Archivo: 10-ritual/14-revision-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Join_Review</bpmn:incoming>
      <bpmn:outgoing>F_Review_Gemba</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Revisar">
      <bpmn:text>Archivo: 10-ritual/14-revision-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Revisar" sourceRef="Annotation_Call_Revisar" targetRef="Call_Revisar"/>
    <bpmn:callActivity id="Call_Gemba" name="[15] Ejecutar Gemba" calledElement="Process_Gemba">
      <bpmn:documentation>Proceso externo: Process_Gemba | Archivo: 10-ritual/15-gemba-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Review_Gemba</bpmn:incoming>
      <bpmn:outgoing>F_Gemba_Acept</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Gemba">
      <bpmn:text>Archivo: 10-ritual/15-gemba-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Gemba" sourceRef="Annotation_Call_Gemba" targetRef="Call_Gemba"/>
    <bpmn:exclusiveGateway id="Gateway_Aceptado" name="¿Incremento aceptado?">
      <bpmn:incoming>F_Gemba_Acept</bpmn:incoming>
      <bpmn:outgoing>F_Acept_No</bpmn:outgoing>
      <bpmn:outgoing>F_Acept_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Call_Cierra" name="[16] Cerrar sesión o sprint" calledElement="Process_Cierra">
      <bpmn:documentation>Proceso externo: Process_Cierra | Archivo: 10-ritual/16-cierra-as-is.bpmn</bpmn:documentation>
      <bpmn:incoming>F_Acept_Si</bpmn:incoming>
      <bpmn:outgoing>F_Cierra_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="Annotation_Call_Cierra">
      <bpmn:text>Archivo: 10-ritual/16-cierra-as-is.bpmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Call_Cierra" sourceRef="Annotation_Call_Cierra" targetRef="Call_Cierra"/>
    <bpmn:endEvent id="End_Registrado" name="Incremento registrado; sesión cerrada">
      <bpmn:incoming>F_Cierra_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_Arranca" sourceRef="Start_Sesion" targetRef="Call_Arranca"/>
    <bpmn:sequenceFlow id="F_Arranca_Obj" sourceRef="Call_Arranca" targetRef="Gateway_Objetivo"/>
    <bpmn:sequenceFlow id="F_Obj_No" sourceRef="Gateway_Objetivo" targetRef="Call_QueSigue" name="No"/>
    <bpmn:sequenceFlow id="F_QueSigue_Cont" sourceRef="Call_QueSigue" targetRef="Gateway_Continuar"/>
    <bpmn:sequenceFlow id="F_Cont_No" sourceRef="Gateway_Continuar" targetRef="End_SoloOrientada" name="No"/>
    <bpmn:sequenceFlow id="F_Cont_Si" sourceRef="Gateway_Continuar" targetRef="Gateway_QueClaro" name="Sí"/>
    <bpmn:sequenceFlow id="F_Obj_Si" sourceRef="Gateway_Objetivo" targetRef="Gateway_QueClaro" name="Sí"/>
    <bpmn:sequenceFlow id="F_Claro_No" sourceRef="Gateway_QueClaro" targetRef="Call_Descubre" name="No"/>
    <bpmn:sequenceFlow id="F_Desc_Aprob" sourceRef="Call_Descubre" targetRef="Gateway_QueAprobado"/>
    <bpmn:sequenceFlow id="F_Aprob_No" sourceRef="Gateway_QueAprobado" targetRef="End_DefinicionPendiente" name="No"/>
    <bpmn:sequenceFlow id="F_Aprob_Si" sourceRef="Gateway_QueAprobado" targetRef="Gateway_Plan" name="Sí"/>
    <bpmn:sequenceFlow id="F_Claro_Si" sourceRef="Gateway_QueClaro" targetRef="Gateway_Plan" name="Sí"/>
    <bpmn:sequenceFlow id="F_Plan_Si" sourceRef="Gateway_Plan" targetRef="Call_Planea" name="Sí"/>
    <bpmn:sequenceFlow id="F_Planea_Hum" sourceRef="Call_Planea" targetRef="Gateway_Humano"/>
    <bpmn:sequenceFlow id="F_Plan_No" sourceRef="Gateway_Plan" targetRef="Gateway_Humano" name="No"/>
    <bpmn:sequenceFlow id="F_Hum_Si" sourceRef="Gateway_Humano" targetRef="Call_Construye" name="Sí"/>
    <bpmn:sequenceFlow id="F_Hum_No" sourceRef="Gateway_Humano" targetRef="Call_Desatendido" name="No"/>
    <bpmn:sequenceFlow id="F_Const_Join" sourceRef="Call_Construye" targetRef="Gateway_UnirConstruccion"/>
    <bpmn:sequenceFlow id="F_Des_Join" sourceRef="Call_Desatendido" targetRef="Gateway_UnirConstruccion"/>
    <bpmn:sequenceFlow id="F_Join_Review" sourceRef="Gateway_UnirConstruccion" targetRef="Call_Revisar"/>
    <bpmn:sequenceFlow id="F_Review_Gemba" sourceRef="Call_Revisar" targetRef="Call_Gemba"/>
    <bpmn:sequenceFlow id="F_Gemba_Acept" sourceRef="Call_Gemba" targetRef="Gateway_Aceptado"/>
    <bpmn:sequenceFlow id="F_Acept_No" sourceRef="Gateway_Aceptado" targetRef="Call_Construye" name="No"/>
    <bpmn:sequenceFlow id="F_Acept_Si" sourceRef="Gateway_Aceptado" targetRef="Call_Cierra" name="Sí"/>
    <bpmn:sequenceFlow id="F_Cierra_End" sourceRef="Call_Cierra" targetRef="End_Registrado"/>
    <bpmn:textAnnotation id="Annotation_Desatendido">
      <bpmn:text>[18] es una variante para ejecutar lo reversible sin humano. Las decisiones irreversibles quedan pendientes para el usuario.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Annotation_Desatendido" sourceRef="Annotation_Desatendido" targetRef="Call_Desatendido"/>
    <bpmn:textAnnotation id="Annotation_Leyenda">
      <bpmn:text>NAVEGACIÓN
Cada actividad de borde grueso tiene su archivo debajo. bpmn.io no abre automáticamente archivos externos: usa el nombre visible y la tabla RELACIONES.csv.</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_01_OperarSesion">
    <bpmndi:BPMNPlane id="Plane_Diagram_01_OperarSesion" bpmnElement="Process_OperarSesion">
