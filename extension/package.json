{
  "name": "jidoka-gobierno",
  "displayName": "Jidoka — el gobierno",
  "description": "Ve el grafo del gobierno de tu repo (áreas, gates, documentos-dueño, capacidades, huérfanos) sin salir de VS Code. La extensión autora; los gates deterministas ejecutan.",
  "version": "0.1.0",
  "publisher": "jidoka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArmandoMedina/jidoka.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "jidoka",
    "gobierno",
    "blast-radius",
    "andon"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "jidoka.verGobierno",
        "title": "Jidoka: ver el gobierno",
        "category": "Jidoka"
      },
      {
        "command": "jidoka.ligarCapacidad",
        "title": "Jidoka: ligar codigo a capacidad...",
        "category": "Jidoka"
      },
      {
        "command": "jidoka.quitarLiga",
        "title": "Jidoka: quitar liga codigo-capacidad...",
        "category": "Jidoka"
      },
      {
        "command": "jidoka.parametrizar",
        "title": "Jidoka: parametrizar...",
        "category": "Jidoka"
      },
      {
        "command": "jidoka.verBandeja",
        "title": "Jidoka: ver la bandeja (pendiente de parametrizar)",
        "category": "Jidoka"
      },
      {
        "command": "jidoka.reclasificar",
        "title": "Jidoka: modo avanzado (reclasificar/firmar)...",
        "category": "Jidoka"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jidoka.parametrizar",
          "when": "resourceScheme == file",
          "group": "9_jidoka@1"
        },
        {
          "command": "jidoka.ligarCapacidad",
          "when": "resourceScheme == file",
          "group": "9_jidoka@2"
        },
        {
          "command": "jidoka.quitarLiga",
          "when": "resourceScheme == file",
          "group": "9_jidoka@3"
        },
        {
          "command": "jidoka.reclasificar",
          "when": "resourceScheme == file",
          "group": "9_jidoka@4"
        }
      ]
    }
  }
}
